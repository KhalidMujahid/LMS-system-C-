@model LMS.Models.LiveClass
@{
    ViewData["Title"] = "Manage: " + Model.Title;
    Layout = "_DashboardLayout";
    bool isLive = Model.Status == LMS.Models.LiveClassStatus.Live;
    bool isUpcoming = Model.Status == LMS.Models.LiveClassStatus.Scheduled;
}

<div class="max-w-4xl mx-auto">
    <div class="flex items-center mb-6">
        <a asp-controller="Instructor" asp-action="ManageCourse" asp-route-id="@Model.CourseId" class="p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors mr-3">
            <i class="bi bi-arrow-left text-lg"></i>
        </a>
        <h2 class="text-2xl font-bold text-gray-900">Manage Live Class</h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg text-sm mb-4">
            @TempData["Success"]
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Class Details</h3>
                
                <div class="space-y-4">
                    <div>
                        <label class="text-sm text-gray-500">Title</label>
                        <p class="font-medium text-gray-900">@Model.Title</p>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div>
                            <label class="text-sm text-gray-500">Description</label>
                            <p class="text-gray-700">@Model.Description</p>
                        </div>
                    }
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="text-sm text-gray-500">Scheduled Time</label>
                            <p class="font-medium text-gray-900">@Model.ScheduledAt.ToString("MMM d, yyyy 'at' h:mm tt")</p>
                        </div>
                        <div>
                            <label class="text-sm text-gray-500">Duration</label>
                            <p class="font-medium text-gray-900">@Model.DurationMinutes minutes</p>
                        </div>
                    </div>
                    
                    <div>
                        <label class="text-sm text-gray-500">Meeting URL</label>
                        <div class="flex items-center gap-2 mt-1">
                            <input type="text" value="@Model.MeetingUrl" readonly class="flex-1 px-3 py-2 border border-gray-300 rounded-lg bg-gray-50 text-sm" />
                            <a href="@Model.MeetingUrl" target="_blank" class="px-3 py-2 bg-primary-600 text-white text-sm rounded-lg hover:bg-primary-700">
                                <i class="bi bi-box-arrow-up-right"></i>
                            </a>
                            <button onclick="navigator.clipboard.writeText('@Model.MeetingUrl')" class="px-3 py-2 border border-gray-300 text-gray-700 text-sm rounded-lg hover:bg-gray-50">
                                <i class="bi bi-clipboard"></i>
                            </button>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.MeetingPassword))
                    {
                        <div>
                            <label class="text-sm text-gray-500">Meeting Password</label>
                            <p class="font-mono text-gray-900">@Model.MeetingPassword</p>
                        </div>
                    }
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Actions</h3>
                
                <div class="space-y-3">
                    @if (isUpcoming)
                    {
                        <form asp-action="Start" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="w-full px-4 py-3 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition-colors flex items-center justify-center">
                                <i class="bi bi-camera-video-fill mr-2"></i>
                                Start Live Session
                            </button>
                        </form>
                        <p class="text-sm text-gray-500 text-center">Start the session to go live with students</p>
                    }
                    else if (isLive)
                    {
                        <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-lg">
                            <span class="w-3 h-3 bg-red-500 rounded-full animate-pulse"></span>
                            <span class="font-medium text-red-700">This session is currently live</span>
                        </div>
                        <a href="@Model.MeetingUrl" target="_blank" class="block w-full px-4 py-3 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition-colors text-center">
                            <i class="bi bi-camera-video-fill mr-2"></i>
                            Join Session
                        </a>
                        <form asp-action="End" method="post" class="mt-3">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="w-full px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors">
                                End Session
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="p-4 bg-gray-50 border border-gray-200 rounded-lg text-center">
                            <p class="text-gray-500">This session has ended</p>
                        </div>
                    }
                    
                    @if (isUpcoming)
                    {
                        <form asp-action="Cancel" method="post" class="pt-3 border-t border-gray-100">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="w-full px-4 py-2 text-red-600 font-medium rounded-lg hover:bg-red-50 transition-colors" onclick="return confirm('Are you sure you want to cancel this live class?');">
                                <i class="bi bi-x-circle mr-2"></i>
                                Cancel Live Class
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Status</h3>
                
                @if (Model.Status == LMS.Models.LiveClassStatus.Live)
                {
                    <div class="flex items-center text-red-600 font-medium">
                        <span class="w-3 h-3 bg-red-500 rounded-full animate-pulse mr-2"></span>
                        LIVE NOW
                    </div>
                }
                else if (Model.Status == LMS.Models.LiveClassStatus.Scheduled)
                {
                    <div class="flex items-center text-primary-600 font-medium">
                        <i class="bi bi-calendar-check mr-2"></i>
                        Scheduled
                    </div>
                }
                else if (Model.Status == LMS.Models.LiveClassStatus.Completed)
                {
                    <div class="flex items-center text-gray-600 font-medium">
                        <i class="bi bi-check-circle mr-2"></i>
                        Completed
                    </div>
                }
                else
                {
                    <div class="flex items-center text-amber-600 font-medium">
                        <i class="bi bi-x-circle mr-2"></i>
                        Cancelled
                    </div>
                }
                
                @if (Model.StartedAt.HasValue)
                {
                    <div class="mt-4 pt-4 border-t border-gray-100">
                        <label class="text-sm text-gray-500">Started</label>
                        <p class="text-gray-900">@Model.StartedAt?.ToString("h:mm tt")</p>
                    </div>
                }
                
                @if (Model.EndedAt.HasValue)
                {
                    <div class="mt-4 pt-4 border-t border-gray-100">
                        <label class="text-sm text-gray-500">Ended</label>
                        <p class="text-gray-900">@Model.EndedAt?.ToString("h:mm tt")</p>
                    </div>
                }
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Course</h3>
                <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId" class="text-primary-600 hover:text-primary-700 font-medium">
                    @Model.Course?.Title
                </a>
                <p class="text-sm text-gray-500 mt-1">@Model.Course?.EnrollmentCount enrolled students</p>
            </div>

            @if (Model.Status != LMS.Models.LiveClassStatus.Live)
            {
                <div class="bg-white rounded-xl shadow-sm border border-red-200 p-6">
                    <h3 class="text-lg font-bold text-red-600 mb-4">Danger Zone</h3>
                    <p class="text-sm text-gray-500 mb-4">Once deleted, this live class cannot be recovered.</p>
                    <form asp-action="Delete" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="w-full px-4 py-2 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition-colors" onclick="return confirm('Are you sure you want to delete this live class?');">
                            <i class="bi bi-trash mr-2"></i>
                            Delete Live Class
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>
