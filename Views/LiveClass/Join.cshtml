@model LMS.Models.LiveClass
@using Microsoft.AspNetCore.Identity
@{
    ViewData["Title"] = "Join Live Class";
    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var isInstructor = Model.InstructorId == userId;
    var isLive = Model.Status == LMS.Models.LiveClassStatus.Live;
    var isUpcoming = Model.Status == LMS.Models.LiveClassStatus.Scheduled && Model.ScheduledAt > DateTime.UtcNow.AddMinutes(-15);
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId" class="inline-flex items-center text-gray-600 hover:text-gray-900 mb-6">
        <i class="bi bi-arrow-left mr-2"></i>Back to Course
    </a>

    <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
        @if (isLive)
        {
            <div class="bg-gradient-to-r from-red-500 to-red-600 text-white px-6 py-4 flex items-center justify-between">
                <div class="flex items-center">
                    <span class="w-3 h-3 bg-white rounded-full animate-pulse mr-3"></span>
                    <span class="font-semibold text-lg">LIVE NOW</span>
                </div>
                <span class="text-white/80 text-sm">Join the session below</span>
            </div>
        }
        else if (isUpcoming)
        {
            <div class="bg-gradient-to-r from-primary-500 to-primary-600 text-white px-6 py-4">
                <span class="font-semibold text-lg">Starting Soon</span>
            </div>
        }
        else if (Model.Status == LMS.Models.LiveClassStatus.Completed)
        {
            <div class="bg-gradient-to-r from-gray-500 to-gray-600 text-white px-6 py-4">
                <span class="font-semibold text-lg">Session Completed</span>
            </div>
        }

        <div class="p-6">
            <div class="mb-6">
                <h1 class="text-2xl font-bold text-gray-900 mb-2">@Model.Title</h1>
                <p class="text-gray-600">@Model.Course?.Title</p>
                
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="mt-3 text-gray-600">@Model.Description</p>
                }
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6 p-4 bg-gray-50 rounded-lg">
                <div class="text-center">
                    <div class="text-2xl font-bold text-gray-900">@Model.ScheduledAt.ToString("MMM d")</div>
                    <div class="text-sm text-gray-500">@Model.ScheduledAt.ToString("yyyy")</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold text-gray-900">@Model.ScheduledAt.ToString("h:mm tt")</div>
                    <div class="text-sm text-gray-500">Start Time</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold text-gray-900">@Model.DurationMinutes</div>
                    <div class="text-sm text-gray-500">Minutes</div>
                </div>
            </div>

            <div class="flex items-center mb-6 pb-6 border-b border-gray-100">
                <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center text-primary-600 font-semibold text-lg">
                    @Model.Instructor?.FullName?.FirstOrDefault() ?? "I"
                </div>
                <div class="ml-3">
                    <p class="font-medium text-gray-900">@(Model.Instructor?.FullName ?? "Instructor")</p>
                    <p class="text-sm text-gray-500">Instructor</p>
                </div>
            </div>

            @if (isLive)
            {
                <div class="text-center">
                    <a href="@Model.MeetingUrl" target="_blank" class="inline-flex items-center px-8 py-4 bg-red-600 text-white font-semibold text-lg rounded-xl hover:bg-red-700 transition-colors shadow-lg hover:shadow-xl">
                        <i class="bi bi-camera-video-fill mr-3 text-xl"></i>
                        Join Live Session
                    </a>
                    <p class="mt-3 text-sm text-gray-500">Opens in a new window</p>
                </div>
            }
            else if (isUpcoming)
            {
                var timeUntil = Model.ScheduledAt - DateTime.UtcNow;
                <div class="text-center">
                    <div class="mb-4">
                        <p class="text-gray-600">This session hasn't started yet</p>
                        @if (timeUntil.TotalMinutes > 0 && timeUntil.TotalMinutes <= 60)
                        {
                            <p class="text-lg font-medium text-primary-600">Starting in @timeUntil.TotalMinutes.ToString("0") minutes</p>
                        }
                        else
                        {
                            <p class="text-lg font-medium text-gray-600">Starting @Model.ScheduledAt.ToString("MMMM d 'at' h:mm tt")</p>
                        }
                    </div>
                    <a href="@Model.MeetingUrl" target="_blank" class="inline-flex items-center px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors">
                        <i class="bi bi-box-arrow-up-right mr-2"></i>
                        Open Meeting Room
                    </a>
                    <p class="mt-3 text-sm text-gray-500">You can join the meeting 15 minutes before the scheduled time</p>
                </div>
            }
            else if (Model.Status == LMS.Models.LiveClassStatus.Completed)
            {
                <div class="text-center py-4">
                    <div class="mx-auto w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mb-3">
                        <i class="bi bi-check-circle text-3xl text-green-600"></i>
                    </div>
                    <p class="text-lg font-medium text-gray-900">This session has ended</p>
                    <p class="text-gray-500 mt-1">Thank you for attending!</p>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <div class="mx-auto w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mb-3">
                        <i class="bi bi-x-circle text-3xl text-gray-400"></i>
                    </div>
                    <p class="text-lg font-medium text-gray-900">This session was cancelled</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.MeetingPassword))
            {
                <div class="mt-6 p-4 bg-amber-50 border border-amber-200 rounded-lg">
                    <p class="text-sm font-medium text-amber-800">
                        <i class="bi bi-lock-fill mr-2"></i>Meeting Password: @Model.MeetingPassword
                    </p>
                </div>
            }
        </div>
    </div>

    @if (isLive || isUpcoming)
    {
        <div class="mt-6 text-center">
            <p class="text-sm text-gray-500">
                Having trouble? <a href="@Model.MeetingUrl" target="_blank" class="text-primary-600 hover:text-primary-700 font-medium">Click here to open directly</a>
            </p>
        </div>
    }
</div>
