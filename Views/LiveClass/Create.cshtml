@model LMS.Models.LiveClass
@{
    ViewData["Title"] = "Schedule Live Class";
    Layout = "_DashboardLayout";
}

<div class="max-w-2xl mx-auto">
    <div class="flex items-center mb-6">
        <a asp-controller="Instructor" asp-action="ManageCourse" asp-route-id="@Model.CourseId" class="p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors mr-3">
            <i class="bi bi-arrow-left text-lg"></i>
        </a>
        <h2 class="text-2xl font-bold text-gray-900">Schedule Live Class</h2>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="CourseId" />
            
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div asp-validation-summary="All" class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg text-sm mb-4"></div>
            }

            <div class="mb-4 p-4 bg-gray-50 rounded-lg">
                <p class="text-sm text-gray-500">Course</p>
                <p class="font-medium text-gray-900">@Model.Course?.Title</p>
            </div>

            <div class="mb-4">
                <label asp-for="Title" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Title" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" placeholder="e.g., Week 1 Live Q&A Session" />
                <span asp-validation-for="Title" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1">Description (optional)</label>
                <textarea asp-for="Description" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" rows="3" placeholder="What will be covered in this session?"></textarea>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                <div>
                    <label asp-for="ScheduledAt" class="block text-sm font-medium text-gray-700 mb-1">Date & Time</label>
                    <input asp-for="ScheduledAt" type="datetime-local" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" />
                    <span asp-validation-for="ScheduledAt" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="DurationMinutes" class="block text-sm font-medium text-gray-700 mb-1">Duration (minutes)</label>
                    <select asp-for="DurationMinutes" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors bg-white">
                        <option value="30">30 minutes</option>
                        <option value="45">45 minutes</option>
                        <option value="60" selected>1 hour</option>
                        <option value="90">1.5 hours</option>
                        <option value="120">2 hours</option>
                    </select>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="MeetingUrl" class="block text-sm font-medium text-gray-700 mb-1">Meeting URL</label>
                <input asp-for="MeetingUrl" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" placeholder="https://meet.jit.si/your-meeting" />
                <span asp-validation-for="MeetingUrl" class="text-red-500 text-xs mt-1 block"></span>
                <p class="text-xs text-gray-500 mt-1">Enter your Jitsi Meet, Zoom, Google Meet, or any video conferencing link</p>
            </div>

            <div class="mb-6">
                <p class="text-sm font-medium text-gray-700 mb-2">Quick Meeting Links</p>
                <div class="flex flex-wrap gap-2">
                    @if (ViewBag.MeetingUrlSuggestions is string[] urls && urls.Length > 0)
                    {
                        @foreach (var url in urls)
                        {
                            <button type="button" onclick="document.getElementById('MeetingUrl').value = '@url'" class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                                <i class="bi bi-link-45deg mr-1"></i>Jitsi
                            </button>
                        }
                    }
                </div>
            </div>

            <div class="mb-6">
                <label asp-for="MeetingPassword" class="block text-sm font-medium text-gray-700 mb-1">Meeting Password (optional)</label>
                <input asp-for="MeetingPassword" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" placeholder="Leave blank if not required" />
            </div>

            <div class="mb-6">
                <label class="flex items-center">
                    <input asp-for="IsRecordingEnabled" type="checkbox" class="w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500" />
                    <span class="ml-2 text-sm text-gray-700">Enable recording for this session</span>
                </label>
            </div>

            <div class="flex gap-3">
                <button type="submit" class="flex-1 px-4 py-2.5 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors">
                    <i class="bi bi-calendar-plus mr-2"></i>Schedule Class
                </button>
                <a asp-controller="Instructor" asp-action="ManageCourse" asp-route-id="@Model.CourseId" class="px-4 py-2.5 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
