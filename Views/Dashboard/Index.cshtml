@model IEnumerable<LMS.Models.Enrollment>
@{
    ViewData["Title"] = "My Dashboard";
    var user = ViewBag.User as LMS.Models.ApplicationUser;
}

<div class="bg-primary text-white py-5 position-relative overflow-hidden">
    <div class="container position-relative" style="z-index: 2;">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-5 fw-bold mb-2">
                    Welcome back, @user?.FirstName! 👋
                </h1>
                <p class="lead mb-0 opacity-90">
                    Continue your learning journey and achieve your goals
                </p>
            </div>
            <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                <a asp-controller="Courses" asp-action="Index" class="btn btn-light btn-lg shadow">
                    <i class="bi bi-plus-circle me-2"></i>Browse Courses
                </a>
            </div>
        </div>
    </div>
    <div class="position-absolute top-0 start-0 w-100 h-100" style="z-index: 1; opacity: 0.1;">
        <div class="position-absolute" style="top: 20%; right: 10%; animation: float 8s ease-in-out infinite;">
            <i class="bi bi-book fs-1"></i>
        </div>
        <div class="position-absolute" style="bottom: 20%; right: 20%; animation: float 6s ease-in-out infinite 1s;">
            <i class="bi bi-star-fill fs-2"></i>
        </div>
    </div>
</div>

<style>
    @@keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-20px); }
    }
</style>

<div class="container py-5">
    <div class="row g-4 mb-5">
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow stats-card h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted mb-1 small text-uppercase fw-semibold">Enrolled Courses</p>
                            <h2 class="fw-bold mb-0 display-6">@Model.Count()</h2>
                        </div>
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-book fs-3"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="badge bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-graph-up me-1"></i>Active Learning
                        </span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow stats-card h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted mb-1 small text-uppercase fw-semibold">Completed</p>
                            <h2 class="fw-bold mb-0 display-6">@Model.Count(e => e.Status == LMS.Models.EnrollmentStatus.Completed)</h2>
                        </div>
                        <div class="icon-circle bg-success bg-opacity-10 text-success">
                            <i class="bi bi-trophy fs-3"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="badge bg-success bg-opacity-10 text-success">
                            <i class="bi bi-check-circle me-1"></i>Achievements
                        </span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow stats-card h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted mb-1 small text-uppercase fw-semibold">In Progress</p>
                            <h2 class="fw-bold mb-0 display-6">@Model.Count(e => e.Status == LMS.Models.EnrollmentStatus.Active)</h2>
                        </div>
                        <div class="icon-circle bg-warning bg-opacity-10 text-warning">
                            <i class="bi bi-clock-history fs-3"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="badge bg-warning bg-opacity-10 text-warning">
                            <i class="bi bi-hourglass-split me-1"></i>Ongoing
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">My Courses</h3>
            <p class="text-muted mb-0">Track your learning progress</p>
        </div>
        <a asp-controller="Courses" asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-plus-circle me-2"></i>Browse More
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <div class="icon-circle bg-primary bg-opacity-10 text-primary mb-3 mx-auto" style="width: 80px; height: 80px;">
                    <i class="bi bi-book fs-1"></i>
                </div>
                <h4 class="fw-bold mb-2">No courses yet</h4>
                <p class="text-muted mb-4">Start your learning journey by enrolling in a course</p>
                <a asp-controller="Courses" asp-action="Index" class="btn btn-primary btn-lg px-5">
                    <i class="bi bi-search me-2"></i>Explore Courses
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var enrollment in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow hover-card">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge @(enrollment.Status == LMS.Models.EnrollmentStatus.Completed ? "bg-success" : "bg-primary") bg-opacity-10 @(enrollment.Status == LMS.Models.EnrollmentStatus.Completed ? "text-success" : "text-primary") px-3 py-2">
                                    <i class="bi @(enrollment.Status == LMS.Models.EnrollmentStatus.Completed ? "bi-check-circle" : "bi-clock-history") me-1"></i>
                                    @enrollment.Status
                                </span>
                                @if (enrollment.Status == LMS.Models.EnrollmentStatus.Completed)
                                {
                                    <i class="bi bi-trophy-fill text-warning fs-4"></i>
                                }
                            </div>
                            
                            <h5 class="card-title fw-bold mb-2">@enrollment.Course?.Title</h5>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-book me-1"></i>@enrollment.Course?.LessonCount lessons
                            </p>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted fw-semibold">Progress</small>
                                    <small class="fw-bold text-primary">@enrollment.ProgressPercentage%</small>
                                </div>
                                <div class="progress" style="height: 10px;">
                                    <div class="progress-bar" role="progressbar" style="width: @enrollment.ProgressPercentage%" 
                                         aria-valuenow="@enrollment.ProgressPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 p-4 pt-0">
                            <a asp-controller="Courses" asp-action="Learn" asp-route-id="@enrollment.CourseId"
                               class="btn @(enrollment.ProgressPercentage == 0 ? "btn-primary" : "btn-outline-primary") w-100">
                                <i class="bi @(enrollment.ProgressPercentage == 0 ? "bi-play-circle" : "bi-arrow-right-circle") me-2"></i>
                                @(enrollment.ProgressPercentage == 0 ? "Start Learning" : "Continue Learning")
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
