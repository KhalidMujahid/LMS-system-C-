@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "My Learning";
    var enrollments = ViewBag.Enrollments as List<LMS.Models.Enrollment> ?? new List<LMS.Models.Enrollment>();
    var completedCourses = enrollments.Count(e => e.Status == LMS.Models.EnrollmentStatus.Completed);
    var inProgressCourses = enrollments.Count(e => e.Status == LMS.Models.EnrollmentStatus.Active);
    var certificates = ViewBag.Certificates as List<LMS.Models.Certificate> ?? new List<LMS.Models.Certificate>();
    var liveClasses = ViewBag.LiveClasses as List<LMS.Models.LiveClass> ?? new List<LMS.Models.LiveClass>();
}

<div class="space-y-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Enrolled Courses</p>
                    <p class="text-3xl font-bold text-gray-900 mt-1">@enrollments.Count</p>
                </div>
                <div class="w-14 h-14 rounded-xl bg-primary-100 flex items-center justify-center">
                    <i class="bi bi-book text-2xl text-primary-600"></i>
                </div>
            </div>
            <div class="mt-4 flex items-center text-sm">
                <span class="text-green-600 flex items-center">
                    <i class="bi bi-arrow-up mr-1"></i>2 new
                </span>
                <span class="text-gray-400 ml-2">this month</span>
            </div>
        </div>
        
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Completed</p>
                    <p class="text-3xl font-bold text-gray-900 mt-1">@completedCourses</p>
                </div>
                <div class="w-14 h-14 rounded-xl bg-green-100 flex items-center justify-center">
                    <i class="bi bi-check-circle text-2xl text-green-600"></i>
                </div>
            </div>
            <div class="mt-4 flex items-center text-sm">
                <span class="text-green-600 flex items-center">
                    <i class="bi bi-arrow-up mr-1"></i>@completedCourses%
                </span>
                <span class="text-gray-400 ml-2">completion rate</span>
            </div>
        </div>
        
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">In Progress</p>
                    <p class="text-3xl font-bold text-gray-900 mt-1">@inProgressCourses</p>
                </div>
                <div class="w-14 h-14 rounded-xl bg-amber-100 flex items-center justify-center">
                    <i class="bi bi-play-circle text-2xl text-amber-600"></i>
                </div>
            </div>
            <div class="mt-4 flex items-center text-sm">
                <span class="text-amber-600 flex items-center">
                    <i class="bi bi-lightning mr-1"></i>Keep learning
                </span>
            </div>
        </div>
        
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Certificates</p>
                    <p class="text-3xl font-bold text-gray-900 mt-1">@certificates.Count</p>
                </div>
                <div class="w-14 h-14 rounded-xl bg-purple-100 flex items-center justify-center">
                    <i class="bi bi-award text-2xl text-purple-600"></i>
                </div>
            </div>
            <div class="mt-4">
                <a asp-controller="Certificate" asp-action="MyCertificates" class="text-sm text-purple-600 hover:text-purple-700 flex items-center">
                    <i class="bi bi-download mr-1"></i>View Certificates
                </a>
            </div>
        </div>
    </div>

    @if (enrollments.Any(e => e.Status == LMS.Models.EnrollmentStatus.Active))
    {
        <div>
            <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
                <i class="bi bi-play-circle text-primary-600 mr-2"></i>
                Continue Learning
            </h2>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                @foreach (var enrollment in enrollments.Where(e => e.Status == LMS.Models.EnrollmentStatus.Active).Take(4))
                {
                    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:border-primary-300 hover:shadow-md transition-all group">
                        <div class="flex">
                            @if (!string.IsNullOrEmpty(enrollment.Course?.ThumbnailUrl))
                            {
                                <div class="w-32 h-32 flex-shrink-0 overflow-hidden">
                                    <img src="@enrollment.Course.ThumbnailUrl" alt="@enrollment.Course.Title" class="w-full h-full object-cover" />
                                </div>
                            }
                            else
                            {
                                <div class="w-32 h-32 bg-gradient-to-br from-primary-500 to-primary-700 flex items-center justify-center flex-shrink-0">
                                    <i class="bi bi-book text-4xl text-white/80"></i>
                                </div>
                            }
                            <div class="flex-1 p-4">
                                <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors line-clamp-1">@enrollment.Course?.Title</h3>
                                <p class="text-gray-500 text-sm mt-1">@enrollment.Course?.Instructor?.FullName</p>
                                
                                <div class="mt-3">
                                    <div class="flex justify-between text-xs text-gray-400 mb-1">
                                        <span>Progress</span>
                                        <span>@(enrollment.ProgressPercentage)%</span>
                                    </div>
                                    <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                                        <div class="h-full bg-gradient-to-r from-primary-500 to-primary-400 rounded-full transition-all duration-500" style="width: @(enrollment.ProgressPercentage)%"></div>
                                    </div>
                                </div>
                                
                                <a asp-controller="Courses" asp-action="Learn" asp-route-id="@enrollment.CourseId" class="inline-flex items-center mt-3 text-sm text-primary-600 hover:text-primary-700">
                                    <i class="bi bi-play-fill mr-1"></i>Continue
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    
    @if (liveClasses.Any())
    {
        <div>
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-bold text-gray-900 flex items-center">
                    <i class="bi bi-camera-video text-red-500 mr-2"></i>
                    Upcoming Live Classes
                </h2>
                <a asp-controller="LiveClass" asp-action="Index" class="text-primary-600 hover:text-primary-700 text-sm flex items-center">
                    View All <i class="bi bi-arrow-right ml-1"></i>
                </a>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var liveClass in liveClasses)
                {
                    <div class="bg-white rounded-xl border border-red-200 overflow-hidden hover:shadow-lg transition-all">
                        <div class="bg-red-500 text-white px-4 py-2 text-sm font-medium flex items-center justify-between">
                            <span>@liveClass.ScheduledAt.ToString("MMM d, yyyy")</span>
                            <span>@liveClass.ScheduledAt.ToString("h:mm tt")</span>
                        </div>
                        <div class="p-4">
                            <h3 class="font-semibold text-gray-900 mb-1">@liveClass.Title</h3>
                            <p class="text-sm text-gray-500 mb-3">@liveClass.Course?.Title</p>
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-gray-500">
                                    <i class="bi bi-clock mr-1"></i>@liveClass.DurationMinutes min
                                </span>
                                <a asp-controller="LiveClass" asp-action="Join" asp-route-id="@liveClass.Id" class="px-3 py-1.5 bg-red-500 text-white text-sm font-medium rounded-lg hover:bg-red-600 transition-colors">
                                    Join
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div>
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-gray-900 flex items-center">
                <i class="bi bi-collection text-primary-600 mr-2"></i>
                My Courses
            </h2>
            <a asp-controller="Courses" asp-action="Index" class="text-primary-600 hover:text-primary-700 text-sm flex items-center">
                Browse More <i class="bi bi-arrow-right ml-1"></i>
            </a>
        </div>
        
        @if (enrollments.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var enrollment in enrollments)
                {
                    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:border-gray-300 hover:shadow-lg transition-all group">
                        @if (!string.IsNullOrEmpty(enrollment.Course?.ThumbnailUrl))
                        {
                            <div class="h-36 relative overflow-hidden">
                                <img src="@enrollment.Course.ThumbnailUrl" alt="@enrollment.Course.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                                <div class="absolute inset-0 bg-gradient-to-t from-gray-900/50 to-transparent"></div>
                            </div>
                        }
                        else
                        {
                            <div class="h-36 bg-gradient-to-br from-gray-100 to-gray-200 relative overflow-hidden">
                                <div class="absolute inset-0 bg-gradient-to-t from-gray-900/50 to-transparent"></div>
                            </div>
                        }
                        <div class="p-4 relative">
                            <div class="absolute top-3 right-3">
                                @if (enrollment.Status == LMS.Models.EnrollmentStatus.Completed)
                                {
                                    <span class="px-2 py-1 bg-green-100 text-green-700 text-xs font-medium rounded-full flex items-center">
                                        <i class="bi bi-check-circle mr-1"></i>Completed
                                    </span>
                                }
                                else if (enrollment.Status == LMS.Models.EnrollmentStatus.Active)
                                {
                                    <span class="px-2 py-1 bg-amber-100 text-amber-700 text-xs font-medium rounded-full flex items-center">
                                        <i class="bi bi-play-circle mr-1"></i>In Progress
                                    </span>
                                }
                            </div>
                            <div class="absolute bottom-3 left-3">
                                <i class="bi bi-book text-3xl text-gray-400"></i>
                            </div>
                        </div>
                        <div class="p-4">
                            <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors line-clamp-1">@enrollment.Course?.Title</h3>
                            <p class="text-gray-500 text-sm mt-1">@enrollment.Course?.Instructor?.FullName</p>
                            
                            <div class="flex items-center justify-between mt-4">
                                <div class="flex items-center text-xs text-gray-400">
                                    <i class="bi bi-clock mr-1"></i>
                                    @enrollment.Course?.LessonCount lessons
                                </div>
                                <div class="flex -space-x-2">
                                    @if (enrollment.Course?.LessonCount > 0)
                                    {
                                        <div class="w-6 h-6 rounded-full bg-primary-600 flex items-center justify-center text-white text-xs border-2 border-white">
                                            @(enrollment.ProgressPercentage)%
                                        </div>
                                    }
                                </div>
                            </div>
                            
                            <a asp-controller="Courses" asp-action="Learn" asp-route-id="@enrollment.CourseId" class="block w-full mt-4 py-2 text-center bg-gray-100 hover:bg-primary-600 text-gray-700 hover:text-white rounded-lg transition-colors">
                                @(enrollment.Status == LMS.Models.EnrollmentStatus.Completed ? "Review Course" : "Continue Learning")
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
                <div class="w-20 h-20 mx-auto bg-gray-100 rounded-full flex items-center justify-center mb-4">
                    <i class="bi bi-book text-3xl text-gray-400"></i>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">No courses yet</h3>
                <p class="text-gray-500 mb-6">Start your learning journey by enrolling in a course</p>
                <a asp-controller="Courses" asp-action="Index" class="inline-flex items-center px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
                    <i class="bi bi-search mr-2"></i>Browse Courses
                </a>
            </div>
        }
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6">
        <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
            <i class="bi bi-activity text-primary-600 mr-2"></i>
            Recent Activity
        </h2>
        <div class="space-y-4">
            @if (enrollments.Any())
            {
                @foreach (var enrollment in enrollments.OrderByDescending(e => e.EnrolledAt).Take(5))
                {
                    <div class="flex items-center gap-4 p-3 rounded-lg bg-gray-50">
                        <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center">
                            <i class="bi bi-book text-primary-600"></i>
                        </div>
                        <div class="flex-1">
                            <p class="text-gray-900">Enrolled in <span class="text-primary-600 font-medium">@enrollment.Course?.Title</span></p>
                            <p class="text-gray-400 text-sm">@enrollment.EnrolledAt.ToString("MMM dd, yyyy")</p>
                        </div>
                        <span class="px-2 py-1 bg-green-100 text-green-700 text-xs rounded-full">
                            Active
                        </span>
                    </div>
                }
            }
            else
            {
                <p class="text-gray-400 text-center py-4">No recent activity</p>
            }
        </div>
    </div>
</div>
