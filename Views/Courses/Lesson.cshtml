@model LMS.Models.Lesson
@{
    ViewData["Title"] = Model.Title;
    bool isCompleted = ViewBag.IsCompleted;
    var prevLesson = ViewBag.PreviousLesson as LMS.Models.Lesson;
    var nextLesson = ViewBag.NextLesson as LMS.Models.Lesson;
    var allLessons = ViewBag.AllLessons as List<LMS.Models.Lesson> ?? new();
}

<div class="min-h-screen bg-gray-50">
    <div class="flex flex-col lg:flex-row min-h-[calc(100vh-64px)]">
        <div class="w-full lg:w-72 bg-white border-r border-gray-200 lg:h-screen lg:sticky lg:top-16 overflow-y-auto">
            <div class="p-4 border-b border-gray-200">
                <p class="text-sm font-bold text-gray-500 uppercase tracking-wide">@Model.Course?.Title</p>
            </div>
            <div class="p-2">
                @foreach (var lesson in allLessons)
                {
                    <a asp-action="Lesson" asp-route-id="@lesson.Id"
                       class="block p-3 rounded-lg mb-1 transition-colors @(lesson.Id == Model.Id ? "bg-primary-50 text-primary-700 border-l-4 border-primary-600" : "text-gray-600 hover:bg-gray-50")">
                        <p class="text-sm font-medium">@lesson.Order. @lesson.Title</p>
                    </a>
                }
            </div>
        </div>

        <div class="flex-1 p-6 lg:p-8">
            <div class="max-w-4xl mx-auto">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
                    <div>
                        <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 text-sm font-medium rounded-full mr-2">@Model.Type</span>
                        <span class="text-gray-500 text-sm">
                            <i class="bi bi-clock mr-1"></i>@Model.DurationMinutes min
                        </span>
                    </div>
                    @if (isCompleted)
                    {
                        <span class="mt-2 sm:mt-0 inline-flex items-center px-3 py-1 bg-green-100 text-green-700 text-sm font-medium rounded-full">
                            <i class="bi bi-check-circle mr-1"></i>Completed
                        </span>
                    }
                </div>

                <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-6">@Model.Title</h1>

                @if (Model.Type == LMS.Models.LessonType.Video && !string.IsNullOrEmpty(Model.VideoUrl))
                {
                    <div class="aspect-video bg-gray-900 rounded-xl overflow-hidden mb-6 shadow-lg">
                        <iframe src="@Model.VideoUrl" class="w-full h-full" allowfullscreen></iframe>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Content))
                {
                    <div class="prose prose-lg max-w-none">
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                            @Html.Raw(Model.Content?.Replace("\n", "<br />"))
                        </div>
                    </div>
                }

                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mt-8 pt-6 border-t border-gray-200">
                    <div class="mb-4 sm:mb-0">
                        @if (prevLesson != null)
                        {
                            <a asp-action="Lesson" asp-route-id="@prevLesson.Id" class="inline-flex items-center px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors">
                                <i class="bi bi-arrow-left mr-2"></i>Previous
                            </a>
                        }
                    </div>
                    <div class="flex flex-col sm:flex-row gap-3">
                        @if (!isCompleted)
                        {
                            <form asp-action="CompleteLesson" method="post">
                                <input type="hidden" name="lessonId" value="@Model.Id" />
                                <button type="submit" class="w-full sm:w-auto px-4 py-2 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition-colors">
                                    <i class="bi bi-check-circle mr-2"></i>Mark Complete
                                </button>
                            </form>
                        }
                        @if (nextLesson != null)
                        {
                            <a asp-action="Lesson" asp-route-id="@nextLesson.Id" class="inline-flex items-center justify-center px-4 py-2 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors">
                                Next <i class="bi bi-arrow-right ml-2"></i>
                            </a>
                        }
                        else
                        {
                            <a asp-action="Learn" asp-route-id="@Model.CourseId" class="inline-flex items-center justify-center px-4 py-2 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors">
                                Back to Course <i class="bi bi-arrow-right ml-2"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
