@model LMS.Models.QuizAttempt
@{
    ViewData["Title"] = "Quiz Result";
}

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="bg-white rounded-xl shadow-lg border border-gray-100 p-8 text-center mb-8">
        @if (Model.Passed)
        {
            <div class="mb-4">
                <i class="bi bi-trophy-fill text-amber-500 text-6xl"></i>
            </div>
            <h1 class="text-2xl font-bold text-green-600 mb-2">Congratulations! 🎉</h1>
            <p class="text-gray-600 text-lg mb-4">You passed the quiz!</p>
        }
        else
        {
            <div class="mb-4">
                <i class="bi bi-x-circle text-red-500 text-6xl"></i>
            </div>
            <h1 class="text-2xl font-bold text-red-600 mb-2">Almost there!</h1>
            <p class="text-gray-600 text-lg mb-4">You didn't pass this time. Keep studying and try again!</p>
        }
        
        <div class="text-5xl font-bold @(Model.Passed ? "text-green-600" : "text-red-600") mb-2">
            @Model.Score%
        </div>
        <p class="text-gray-500 mb-6">Pass score: @Model.Quiz?.PassingScore%</p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a asp-controller="Courses" asp-action="Learn" asp-route-id="@Model.Quiz?.CourseId" class="inline-flex items-center px-4 py-2 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors">
                <i class="bi bi-arrow-left mr-2"></i>Back to Course
            </a>
            @if (!Model.Passed)
            {
                <a asp-controller="Courses" asp-action="TakeQuiz" asp-route-id="@Model.QuizId" class="inline-flex items-center px-4 py-2 border border-primary-600 text-primary-600 font-medium rounded-lg hover:bg-primary-50 transition-colors">
                    <i class="bi bi-arrow-repeat mr-2"></i>Retry Quiz
                </a>
            }
        </div>
    </div>

    <h2 class="text-xl font-bold text-gray-900 mb-4">Answer Review</h2>
    <div class="space-y-4">
        @foreach (var question in Model.Quiz?.Questions.OrderBy(q => q.Order) ?? Enumerable.Empty<LMS.Models.Question>())
        {
            var studentAnswer = Model.StudentAnswers.FirstOrDefault(sa => sa.QuestionId == question.Id);
            var correct = question.Answers.FirstOrDefault(a => a.IsCorrect);
            bool isRight = studentAnswer?.AnswerId == correct?.Id;

            <div class="bg-white rounded-xl shadow-sm border @(isRight ? "border-green-200" : "border-red-200") overflow-hidden">
                <div class="p-4">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="font-bold text-gray-900">@question.Text</h3>
                        <span class="px-3 py-1 rounded-full text-xs font-medium @(isRight ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                            @(isRight ? "Correct" : "Wrong")
                        </span>
                    </div>
                    <p class="text-sm mb-2">
                        <span class="font-medium">Your answer:</span>
                        <span class="@(isRight ? "text-green-600" : "text-red-600")">
                            @(studentAnswer != null ? question.Answers.FirstOrDefault(a => a.Id == studentAnswer.AnswerId)?.Text : "Not answered")
                        </span>
                    </p>
                    @if (!isRight)
                    {
                        <p class="text-sm text-green-600">
                            <span class="font-medium">Correct answer:</span> @correct?.Text
                        </p>
                    }
                </div>
            </div>
        }
    </div>
</div>
