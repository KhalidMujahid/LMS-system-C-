@model IEnumerable<LMS.Models.Course>
@{
    ViewData["Title"] = "Courses";
    var enrolledIds = ViewBag.EnrolledCourseIds as List<int> ?? new List<int>();
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<div class="bg-gray-50 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-900 mb-2">Explore Courses</h1>
            <p class="text-gray-600">Discover courses to advance your skills</p>
        </div>

        <form method="get" class="max-w-3xl mx-auto">
            <div class="flex flex-col sm:flex-row gap-3">
                <input type="text" name="search" class="flex-1 px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors"
                       placeholder="Search courses..." value="@ViewBag.Search" />
                <select name="category" class="px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none bg-white">
                    <option value="">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat" selected="@(ViewBag.SelectedCategory == cat ? "selected" : null)">@cat</option>
                    }
                </select>
                <button type="submit" class="px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors">
                    <i class="bi bi-search mr-1"></i>Search
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.SelectedCategory as string))
                {
                    <a asp-action="Index" class="px-6 py-3 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors">
                        Clear
                    </a>
                }
            </div>
        </form>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    @if (!Model.Any())
    {
        <div class="text-center py-16">
            <div class="mx-auto h-24 w-24 bg-gray-100 rounded-full flex items-center justify-center mb-4">
                <i class="bi bi-search text-4xl text-gray-400"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">No courses found</h3>
            <p class="text-gray-500">Try different search terms.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var course in Model)
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 group">
                    @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                    {
                        <div class="h-40 overflow-hidden">
                            <img src="@course.ThumbnailUrl" alt="@course.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                        </div>
                    }
                    else
                    {
                        <div class="h-40 bg-gradient-to-br from-primary-500 to-primary-700 flex items-center justify-center">
                            <i class="bi bi-book text-5xl text-white opacity-50"></i>
                        </div>
                    }
                    <div class="p-6">
                        @if (course.Category != null)
                        {
                            <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 text-xs font-medium rounded-full mb-3">@course.Category</span>
                        }
                        <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-primary-600 transition-colors line-clamp-2">@course.Title</h3>
                        <p class="text-gray-500 text-sm mb-4 line-clamp-2">@(course.Description.Length > 100 ? course.Description[..100] + "..." : course.Description)</p>
                        
                        <div class="flex items-center gap-4 text-gray-500 text-sm pt-4 border-t border-gray-100">
                            <span class="flex items-center">
                                <i class="bi bi-person mr-1"></i>@course.Instructor?.FullName
                            </span>
                            <span class="flex items-center">
                                <i class="bi bi-book mr-1"></i>@course.LessonCount
                            </span>
                            <span class="flex items-center">
                                <i class="bi bi-people mr-1"></i>@course.EnrollmentCount
                            </span>
                        </div>
                    </div>
                    <div class="px-6 pb-6">
                        <div class="flex items-center justify-between">
                            <div class="font-bold text-lg">
                                @if (course.Price > 0)
                                {
                                    <span class="text-gray-900">@course.PriceInNaira.ToString("₦#,##0.00")</span>
                                }
                                else
                                {
                                    <span class="text-green-600">Free</span>
                                }
                            </div>
                            @if (enrolledIds.Contains(course.Id))
                            {
                                <a asp-action="Learn" asp-route-id="@course.Id" class="px-4 py-2 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition-colors">
                                    <i class="bi bi-play-circle mr-1"></i>Continue
                                </a>
                            }
                            else
                            {
                                <a asp-action="Details" asp-route-id="@course.Id" class="px-4 py-2 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors">
                                    View Course
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
