@model IEnumerable<LMS.Models.Course>
@{
    ViewData["Title"] = "Courses";
    var enrolledIds = ViewBag.EnrolledCourseIds as List<int> ?? new List<int>();
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<div class="bg-light py-4">
    <div class="container">
        <h2 class="fw-bold">Explore Courses</h2>
        <p class="text-muted">Discover courses to advance your skills</p>

        <form method="get" class="d-flex gap-2 flex-wrap">
            <input type="text" name="search" class="form-control" style="max-width:300px;"
                   placeholder="Search courses..." value="@ViewBag.Search" />
            <select name="category" class="form-select" style="max-width:200px;">
                <option value="">All Categories</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat" selected="@(ViewBag.SelectedCategory == cat ? "selected" : null)">@cat</option>
                }
            </select>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-1"></i>Search
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.SelectedCategory as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            }
        </form>
    </div>
</div>

<div class="container py-4">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-search text-muted" style="font-size:4rem;"></i>
            <h4 class="mt-3">No courses found</h4>
            <p class="text-muted">Try different search terms.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var course in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm hover-card">
                        <div class="card-body">
                            @if (course.Category != null)
                            {
                                <span class="badge bg-secondary mb-2">@course.Category</span>
                            }
                            <h5 class="card-title">@course.Title</h5>
                            <p class="card-text text-muted small">@(course.Description.Length > 100 ? course.Description[..100] + "..." : course.Description)</p>
                            <div class="d-flex gap-3 text-muted small mt-auto">
                                <span><i class="bi bi-person me-1"></i>@course.Instructor?.FullName</span>
                                <span><i class="bi bi-book me-1"></i>@course.LessonCount lessons</span>
                                <span><i class="bi bi-people me-1"></i>@course.EnrollmentCount students</span>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            @if (enrolledIds.Contains(course.Id))
                            {
                                <a asp-action="Learn" asp-route-id="@course.Id" class="btn btn-success btn-sm w-100">
                                    <i class="bi bi-play-circle me-1"></i>Continue Learning
                                </a>
                            }
                            else
                            {
                                <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-primary btn-sm w-100">
                                    View Course
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
