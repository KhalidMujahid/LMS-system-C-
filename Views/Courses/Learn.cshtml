@model LMS.Models.Enrollment
@{
    ViewData["Title"] = "Learn - " + Model.Course?.Title;
    var completedLessons = ViewBag.CompletedLessons as List<int> ?? new List<int>();
    var lessons = Model.Course?.Lessons.OrderBy(l => l.Order).ToList() ?? new List<LMS.Models.Lesson>();
}

<div class="bg-gradient-to-r from-primary-600 to-primary-800 text-white py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between">
            <div class="mb-4 md:mb-0">
                <h3 class="text-xl font-bold mb-1">@Model.Course?.Title</h3>
                <p class="text-primary-100 text-sm">@completedLessons.Count / @lessons.Count lessons completed</p>
            </div>
            <div class="w-full md:w-64">
                <div class="w-full bg-white/20 rounded-full h-2 mb-1">
                    <div class="bg-green-400 h-2 rounded-full transition-all duration-300" style="width: @Model.ProgressPercentage%"></div>
                </div>
                <p class="text-right text-sm text-primary-100">@Model.ProgressPercentage% complete</p>
            </div>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
            <h3 class="text-xl font-bold text-gray-900 mb-4">
                <i class="bi bi-book mr-2 text-primary-600"></i>Course Lessons
            </h3>
            
            @if (lessons.Any())
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-6">
                    @foreach (var lesson in lessons)
                    {
                        bool isCompleted = completedLessons.Contains(lesson.Id);
                        <a asp-action="Lesson" asp-route-id="@lesson.Id"
                           class="flex items-center p-4 border-b border-gray-100 last:border-b-0 hover:bg-gray-50 transition-colors">
                            <span class="@(isCompleted ? "text-green-500" : "text-gray-400") mr-4">
                                <i class="bi bi-@(isCompleted ? "check-circle-fill" : "circle") text-xl"></i>
                            </span>
                            <div class="flex-1">
                                <p class="font-medium text-gray-900">@lesson.Order. @lesson.Title</p>
                                <span class="text-sm text-gray-500">@lesson.DurationMinutes min</span>
                            </div>
                            @if (isCompleted)
                            {
                                <span class="px-2 py-1 bg-green-100 text-green-700 text-xs font-medium rounded-full">Done</span>
                            }
                        </a>
                    }
                </div>
            }

            @if (Model.Course?.Quizzes.Any() == true)
            {
                <h3 class="text-xl font-bold text-gray-900 mb-4">
                    <i class="bi bi-patch-question mr-2 text-amber-500"></i>Quizzes
                </h3>
                <div class="space-y-3">
                    @foreach (var quiz in Model.Course.Quizzes)
                    {
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 flex items-center justify-between">
                            <div>
                                <h4 class="font-bold text-gray-900">@quiz.Title</h4>
                                <p class="text-sm text-gray-500">@quiz.Questions.Count questions • Pass: @quiz.PassingScore%</p>
                            </div>
                            <a asp-action="TakeQuiz" asp-route-id="@quiz.Id" class="px-4 py-2 bg-amber-500 text-white font-medium rounded-lg hover:bg-amber-600 transition-colors">
                                <i class="bi bi-play mr-1"></i>Take Quiz
                            </a>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="lg:col-span-1">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 sticky top-24">
                <h4 class="font-bold text-gray-900 mb-4">Your Progress</h4>
                <div class="w-full bg-gray-100 rounded-full h-3 mb-2">
                    <div class="bg-primary-600 h-3 rounded-full transition-all duration-300" style="width: @Model.ProgressPercentage%"></div>
                </div>
                <p class="text-sm text-gray-500 text-center mb-4">@Model.ProgressPercentage% complete</p>
                
                @if (Model.Status == LMS.Models.EnrollmentStatus.Completed)
                {
                    <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-center">
                        <i class="bi bi-trophy-fill text-amber-500 text-2xl mb-2"></i>
                        <p class="text-green-800 font-medium">Course Completed! 🎉</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
