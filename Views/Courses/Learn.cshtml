@model LMS.Models.Enrollment
@{
    ViewData["Title"] = "Learn - " + Model.Course?.Title;
    var completedLessons = ViewBag.CompletedLessons as List<int> ?? new List<int>();
    var lessons = Model.Course?.Lessons.OrderBy(l => l.Order).ToList() ?? new List<LMS.Models.Lesson>();
}

<div class="bg-primary text-white py-3">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <h4 class="mb-0 fw-bold">@Model.Course?.Title</h4>
            <small>@completedLessons.Count / @lessons.Count lessons completed</small>
        </div>
        <div>
            <div class="progress" style="width:200px; height:8px;">
                <div class="progress-bar bg-success" style="width:@Model.ProgressPercentage%"></div>
            </div>
            <small>@Model.ProgressPercentage% complete</small>
        </div>
    </div>
</div>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-8">
            <h5 class="fw-bold mb-3"><i class="bi bi-book me-2 text-primary"></i>Course Lessons</h5>
            @if (lessons.Any())
            {
                <div class="list-group mb-4">
                    @foreach (var lesson in lessons)
                    {
                        bool isCompleted = completedLessons.Contains(lesson.Id);
                        <a asp-action="Lesson" asp-route-id="@lesson.Id"
                           class="list-group-item list-group-item-action d-flex align-items-center gap-3">
                            <span class="@(isCompleted ? "text-success" : "text-muted")">
                                <i class="bi bi-@(isCompleted ? "check-circle-fill" : "circle") fs-5"></i>
                            </span>
                            <span class="flex-grow-1">
                                <strong>@lesson.Order. @lesson.Title</strong>
                                <small class="d-block text-muted">@lesson.DurationMinutes min</small>
                            </span>
                            @if (isCompleted)
                            {
                                <span class="badge bg-success">Done</span>
                            }
                        </a>
                    }
                </div>
            }

            @if (Model.Course?.Quizzes.Any() == true)
            {
                <h5 class="fw-bold mb-3"><i class="bi bi-patch-question me-2 text-warning"></i>Quizzes</h5>
                @foreach (var quiz in Model.Course.Quizzes)
                {
                    <div class="card mb-3">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">@quiz.Title</h6>
                                <small class="text-muted">@quiz.Questions.Count questions • Pass: @quiz.PassingScore%</small>
                            </div>
                            <a asp-action="TakeQuiz" asp-route-id="@quiz.Id" class="btn btn-warning btn-sm">
                                <i class="bi bi-play me-1"></i>Take Quiz
                            </a>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold">Your Progress</h6>
                    <div class="progress mb-2" style="height:12px;">
                        <div class="progress-bar" style="width:@Model.ProgressPercentage%"></div>
                    </div>
                    <small class="text-muted">@Model.ProgressPercentage% complete</small>
                    @if (Model.Status == LMS.Models.EnrollmentStatus.Completed)
                    {
                        <div class="alert alert-success mt-3 mb-0">
                            <i class="bi bi-trophy-fill me-2"></i>Course Completed! 🎉
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
