@model LMS.Models.Quiz
@{
    ViewData["Title"] = "Quiz: " + Model.Title;
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
        <h1 class="text-2xl font-bold text-gray-900 mb-2">@Model.Title</h1>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-gray-600 mb-4">@Model.Description</p>
        }
        <div class="flex flex-wrap items-center gap-4 text-sm">
            <span class="flex items-center text-amber-600">
                <i class="bi bi-patch-question mr-1.5"></i>@Model.Questions.Count questions
            </span>
            <span class="flex items-center text-blue-600">
                <i class="bi bi-clock mr-1.5"></i>@Model.TimeLimitMinutes min limit
            </span>
            <span class="flex items-center text-green-600">
                <i class="bi bi-check2-circle mr-1.5"></i>Pass: @Model.PassingScore%
            </span>
        </div>
    </div>

    <form asp-action="SubmitQuiz" method="post">
        <input type="hidden" name="quizId" value="@Model.Id" />

        @{ int qNum = 1; }
        @foreach (var question in Model.Questions.OrderBy(q => q.Order))
        {
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-4">
                <div class="mb-4">
                    <h3 class="text-lg font-bold text-gray-900">Question @qNum: @question.Text</h3>
                    <span class="text-sm text-gray-500">(@question.Points point@(question.Points != 1 ? "s" : ""))</span>
                </div>
                <div class="space-y-3">
                    @foreach (var answer in question.Answers)
                    {
                        <label class="flex items-center p-4 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50 transition-colors" for="answer_@answer.Id">
                            <input class="w-4 h-4 text-primary-600 focus:ring-primary-500 border-gray-300" type="radio"
                                   name="answers[@question.Id]" value="@answer.Id"
                                   id="answer_@answer.Id" required />
                            <span class="ml-3 text-gray-700">@answer.Text</span>
                        </label>
                    }
                </div>
            </div>
            qNum++;
        }

        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <a asp-action="Learn" asp-route-id="@Model.CourseId" class="inline-flex items-center px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors">
                <i class="bi bi-arrow-left mr-2"></i>Back to Course
            </a>
            <button type="submit" class="inline-flex items-center justify-center px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors">
                <i class="bi bi-send mr-2"></i>Submit Quiz
            </button>
        </div>
    </form>
</div>
