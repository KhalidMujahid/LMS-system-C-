@model LMS.Models.Quiz
@{
    ViewData["Title"] = "Quiz: " + Model.Title;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h3 class="fw-bold">@Model.Title</h3>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p class="text-muted">@Model.Description</p>
                    }
                    <div class="d-flex gap-4 small">
                        <span><i class="bi bi-patch-question me-1 text-warning"></i>@Model.Questions.Count questions</span>
                        <span><i class="bi bi-clock me-1 text-info"></i>@Model.TimeLimitMinutes min limit</span>
                        <span><i class="bi bi-check2-circle me-1 text-success"></i>Pass: @Model.PassingScore%</span>
                    </div>
                </div>
            </div>

            <form asp-action="SubmitQuiz" method="post">
                <input type="hidden" name="quizId" value="@Model.Id" />

                @{ int qNum = 1; }
                @foreach (var question in Model.Questions.OrderBy(q => q.Order))
                {
                    <div class="card mb-4 shadow-sm">
                        <div class="card-body">
                            <h6 class="fw-bold">Question @qNum: @question.Text</h6>
                            <small class="text-muted">(@question.Points point@(question.Points != 1 ? "s" : ""))</small>
                            <div class="mt-3">
                                @foreach (var answer in question.Answers)
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio"
                                               name="answers[@question.Id]" value="@answer.Id"
                                               id="answer_@answer.Id" required />
                                        <label class="form-check-label" for="answer_@answer.Id">
                                            @answer.Text
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    qNum++;
                }

                <div class="d-flex justify-content-between">
                    <a asp-action="Learn" asp-route-id="@Model.CourseId" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back to Course
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-send me-2"></i>Submit Quiz
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
