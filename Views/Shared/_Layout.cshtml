<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
                    },
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex">
                    <div class="flex-shrink-0 flex items-center">
                        <a asp-controller="Home" asp-action="Index" class="text-xl font-bold text-primary-600 hover:text-primary-700 transition-colors">
                            <i class="bi bi-mortarboard-fill mr-2"></i>EduLMS
                        </a>
                    </div>
                    <div class="hidden sm:ml-8 sm:flex sm:space-x-6">
                        <a asp-controller="Courses" asp-action="Index" class="inline-flex items-center px-1 pt-1 text-sm font-medium text-gray-700 hover:text-primary-600 border-b-2 border-transparent hover:border-primary-500 transition-colors">
                            <i class="bi bi-book mr-1.5"></i>Courses
                        </a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Dashboard" asp-action="Index" class="inline-flex items-center px-1 pt-1 text-sm font-medium text-gray-700 hover:text-primary-600 border-b-2 border-transparent hover:border-primary-500 transition-colors">
                                <i class="bi bi-speedometer2 mr-1.5"></i>Dashboard
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Admin" asp-action="Index" class="inline-flex items-center px-1 pt-1 text-sm font-medium text-gray-700 hover:text-primary-600 border-b-2 border-transparent hover:border-primary-500 transition-colors">
                                    <i class="bi bi-shield-check mr-1.5"></i>Admin
                                </a>
                            }
                            @if (User.IsInRole("Instructor") || User.IsInRole("Admin"))
                            {
                                <a asp-controller="Instructor" asp-action="Index" class="inline-flex items-center px-1 pt-1 text-sm font-medium text-gray-700 hover:text-primary-600 border-b-2 border-transparent hover:border-primary-500 transition-colors">
                                    <i class="bi bi-person-workspace mr-1.5"></i>Instructor
                                </a>
                            }
                        }
                    </div>
                </div>
                <div class="hidden sm:ml-6 sm:flex sm:items-center sm:space-x-4">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Cart" asp-action="Index" class="relative p-2 text-gray-600 hover:text-primary-600 transition-colors" title="Shopping Cart">
                            <i class="bi bi-cart text-xl"></i>
                        </a>
                        <div class="relative ml-3">
                            <button type="button" class="flex items-center space-x-2 text-sm font-medium text-gray-700 hover:text-primary-600 focus:outline-none transition-colors" id="user-menu-button">
                                <i class="bi bi-person-circle text-lg"></i>
                                <span>@User.Identity.Name</span>
                                <i class="bi bi-chevron-down text-xs"></i>
                            </button>
                            <div class="hidden absolute right-0 mt-2 w-48 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 py-1">
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                        <i class="bi bi-box-arrow-right mr-2"></i>Logout
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="text-sm font-medium text-gray-700 hover:text-primary-600 px-3 py-2 transition-colors">
                            <i class="bi bi-box-arrow-in-right mr-1"></i>Login
                        </a>
                        <a asp-controller="Account" asp-action="Register" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 transition-colors shadow-sm">
                            <i class="bi bi-person-plus mr-1.5"></i>Register
                        </a>
                    }
                </div>
                <div class="flex items-center sm:hidden">
                    <button type="button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none" id="mobile-menu-button">
                        <i class="bi bi-list text-2xl"></i>
                    </button>
                </div>
            </div>
        </div>
        <div class="hidden sm:hidden bg-white border-t border-gray-200" id="mobile-menu">
            <div class="pt-2 pb-3 space-y-1 px-4">
                <a asp-controller="Courses" asp-action="Index" class="block pl-3 pr-4 py-2 text-base font-medium text-gray-700 hover:text-primary-600 hover:bg-gray-50 border-l-4 border-transparent hover:border-primary-500">
                    <i class="bi bi-book mr-2"></i>Courses
                </a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Dashboard" asp-action="Index" class="block pl-3 pr-4 py-2 text-base font-medium text-gray-700 hover:text-primary-600 hover:bg-gray-50 border-l-4 border-transparent hover:border-primary-500">
                        <i class="bi bi-speedometer2 mr-2"></i>Dashboard
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Index" class="block pl-3 pr-4 py-2 text-base font-medium text-gray-700 hover:text-primary-600 hover:bg-gray-50 border-l-4 border-transparent hover:border-primary-500">
                            <i class="bi bi-shield-check mr-2"></i>Admin
                        </a>
                    }
                    @if (User.IsInRole("Instructor") || User.IsInRole("Admin"))
                    {
                        <a asp-controller="Instructor" asp-action="Index" class="block pl-3 pr-4 py-2 text-base font-medium text-gray-700 hover:text-primary-600 hover:bg-gray-50 border-l-4 border-transparent hover:border-primary-500">
                            <i class="bi bi-person-workspace mr-2"></i>Instructor
                        </a>
                    }
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="block w-full text-left pl-3 pr-4 py-2 text-base font-medium text-gray-700 hover:text-red-600 hover:bg-gray-50 border-l-4 border-transparent">
                            <i class="bi bi-box-arrow-right mr-2"></i>Logout
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="block pl-3 pr-4 py-2 text-base font-medium text-gray-700 hover:text-primary-600 hover:bg-gray-50 border-l-4 border-transparent hover:border-primary-500">
                        <i class="bi bi-box-arrow-in-right mr-2"></i>Login
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="block pl-3 pr-4 py-2 text-base font-medium text-primary-600 hover:text-primary-700 hover:bg-gray-50 border-l-4 border-primary-500">
                        <i class="bi bi-person-plus mr-2"></i>Register
                    </a>
                }
            </div>
        </div>
    </nav>

    <main class="flex-grow">
        @if (TempData["Success"] != null)
        {
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
                <div class="bg-green-50 border border-green-200 rounded-lg p-4 flex items-center" role="alert">
                    <i class="bi bi-check-circle text-green-600 mr-3 text-lg"></i>
                    <span class="text-green-800">@TempData["Success"]</span>
                    <button type="button" class="ml-auto bg-transparent border-0 text-green-600 cursor-pointer" onclick="this.parentElement.remove()">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
                <div class="bg-red-50 border border-red-200 rounded-lg p-4 flex items-center" role="alert">
                    <i class="bi bi-exclamation-circle text-red-600 mr-3 text-lg"></i>
                    <span class="text-red-800">@TempData["Error"]</span>
                    <button type="button" class="ml-auto bg-transparent border-0 text-red-600 cursor-pointer" onclick="this.parentElement.remove()">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="bg-gray-900 text-white mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <div>
                    <h5 class="text-lg font-bold mb-4">
                        <i class="bi bi-mortarboard-fill mr-2 text-primary-400"></i>EduLMS
                    </h5>
                    <p class="text-gray-400 mb-4">
                        Empowering learners worldwide with quality education and innovative learning experiences.
                    </p>
                    <div class="flex space-x-4">
                        <a href="#" class="text-gray-400 hover:text-white transition-colors text-lg" title="Facebook">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="#" class="text-gray-400 hover:text-white transition-colors text-lg" title="Twitter">
                            <i class="bi bi-twitter"></i>
                        </a>
                        <a href="#" class="text-gray-400 hover:text-white transition-colors text-lg" title="LinkedIn">
                            <i class="bi bi-linkedin"></i>
                        </a>
                        <a href="#" class="text-gray-400 hover:text-white transition-colors text-lg" title="Instagram">
                            <i class="bi bi-instagram"></i>
                        </a>
                    </div>
                </div>
                <div>
                    <h6 class="font-semibold mb-4">Quick Links</h6>
                    <ul class="space-y-2">
                        <li>
                            <a href="/" class="text-gray-400 hover:text-white transition-colors">
                                <i class="bi bi-chevron-right mr-1 text-xs"></i>Home
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Courses" asp-action="Index" class="text-gray-400 hover:text-white transition-colors">
                                <i class="bi bi-chevron-right mr-1 text-xs"></i>Courses
                            </a>
                        </li>
                        <li>
                            <a href="#" class="text-gray-400 hover:text-white transition-colors">
                                <i class="bi bi-chevron-right mr-1 text-xs"></i>About Us
                            </a>
                        </li>
                    </ul>
                </div>
                <div>
                    <h6 class="font-semibold mb-4">Support</h6>
                    <ul class="space-y-2">
                        <li>
                            <a href="#" class="text-gray-400 hover:text-white transition-colors">
                                <i class="bi bi-chevron-right mr-1 text-xs"></i>Help Center
                            </a>
                        </li>
                        <li>
                            <a href="#" class="text-gray-400 hover:text-white transition-colors">
                                <i class="bi bi-chevron-right mr-1 text-xs"></i>Contact Us
                            </a>
                        </li>
                        <li>
                            <a href="#" class="text-gray-400 hover:text-white transition-colors">
                                <i class="bi bi-chevron-right mr-1 text-xs"></i>Privacy Policy
                            </a>
                        </li>
                    </ul>
                </div>
                <div>
                    <h6 class="font-semibold mb-4">Newsletter</h6>
                    <p class="text-gray-400 text-sm mb-4">Subscribe to get updates on new courses</p>
                    <div class="flex">
                        <input type="email" placeholder="Your email" class="flex-1 px-4 py-2 bg-gray-800 border border-gray-700 rounded-l-lg text-white placeholder-gray-400 focus:outline-none focus:border-primary-500">
                        <button type="button" class="px-4 py-2 bg-primary-600 hover:bg-primary-700 rounded-r-lg transition-colors">
                            <i class="bi bi-send"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="border-t border-gray-800 mt-8 pt-8">
                <div class="flex flex-col md:flex-row justify-between items-center">
                    <p class="text-gray-400 text-sm">
                        © @DateTime.Now.Year EduLMS. All rights reserved.
                    </p>
                    <p class="text-gray-400 text-sm mt-2 md:mt-0">
                        Made with <i class="bi bi-heart-fill text-red-500 mx-1"></i> for learners everywhere
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const mobileMenuButton = document.getElementById('mobile-menu-button');
        const mobileMenu = document.getElementById('mobile-menu');
        
        if (mobileMenuButton && mobileMenu) {
            mobileMenuButton.addEventListener('click', () => {
                mobileMenu.classList.toggle('hidden');
            });
        }

        const userMenuButton = document.getElementById('user-menu-button');
        const userMenu = userMenuButton?.nextElementSibling;
        
        if (userMenuButton && userMenu) {
            userMenuButton.addEventListener('click', (e) => {
                e.stopPropagation();
                userMenu.classList.toggle('hidden');
            });

            document.addEventListener('click', () => {
                userMenu.classList.add('hidden');
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
