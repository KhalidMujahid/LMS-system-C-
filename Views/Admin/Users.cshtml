@model IEnumerable<LMS.Models.ApplicationUser>
@{
    ViewData["Title"] = "Manage Users";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold">Manage Users</h3>
            <a asp-action="Index" class="text-muted small"><i class="bi bi-arrow-left me-1"></i>Back to Dashboard</a>
        </div>
        <span class="badge bg-secondary fs-6">@Model.Count() users</span>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var roles = userRoles?.GetValueOrDefault(user.Id) ?? new List<string>();
                        var role = roles.FirstOrDefault() ?? "None";
                        <tr>
                            <td class="align-middle">@user.FullName</td>
                            <td class="align-middle">@user.Email</td>
                            <td class="align-middle">
                                <span class="badge @(role == "Admin" ? "bg-danger" : role == "Instructor" ? "bg-success" : "bg-primary")">@role</span>
                            </td>
                            <td class="align-middle">
                                <span class="badge @(user.IsActive ? "bg-success" : "bg-secondary")">@(user.IsActive ? "Active" : "Inactive")</span>
                            </td>
                            <td class="align-middle text-muted small">@user.CreatedAt.ToString("MMM d, yyyy")</td>
                            <td class="align-middle">
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-outline-primary btn-sm me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="DeleteUser" method="post" class="d-inline"
                                      onsubmit="return confirm('Are you sure you want to delete this user?')">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
