@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="bg-dark text-white py-4">
    <div class="container">
        <h2 class="fw-bold"><i class="bi bi-shield-check me-2"></i>Admin Dashboard</h2>
        <p class="text-muted mb-0">Manage your LMS platform</p>
    </div>
</div>

<div class="container py-4">
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <i class="bi bi-people text-primary" style="font-size:2.5rem;"></i>
                <h3 class="fw-bold mt-2">@ViewBag.TotalUsers</h3>
                <p class="text-muted mb-0">Total Users</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <i class="bi bi-book text-success" style="font-size:2.5rem;"></i>
                <h3 class="fw-bold mt-2">@ViewBag.TotalCourses</h3>
                <p class="text-muted mb-0">Total Courses</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <i class="bi bi-person-check text-warning" style="font-size:2.5rem;"></i>
                <h3 class="fw-bold mt-2">@ViewBag.TotalEnrollments</h3>
                <p class="text-muted mb-0">Enrollments</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <i class="bi bi-check-circle text-info" style="font-size:2.5rem;"></i>
                <h3 class="fw-bold mt-2">@ViewBag.PublishedCourses</h3>
                <p class="text-muted mb-0">Published Courses</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold"><i class="bi bi-people me-2 text-primary"></i>Manage Users</h5>
                    <p class="text-muted">View, edit, and delete user accounts. Assign roles.</p>
                    <a asp-action="Users" class="btn btn-primary">Manage Users</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold"><i class="bi bi-book me-2 text-success"></i>Manage Courses</h5>
                    <p class="text-muted">View all courses, monitor enrollment, and remove problematic content.</p>
                    <a asp-action="Courses" class="btn btn-success">Manage Courses</a>
                </div>
            </div>
        </div>
    </div>
</div>
