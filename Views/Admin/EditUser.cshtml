@model LMS.Models.ApplicationUser
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Edit User";
    var allRoles = ViewBag.AllRoles as string[];
    var userRoles = ViewBag.UserRoles as IList<string> ?? new List<string>();
    var currentRole = userRoles.FirstOrDefault() ?? "Student";
}

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-xl font-bold text-gray-900 mb-6">Edit User: @Model.FullName</h2>

        <form asp-action="EditUser" method="post">
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                    <input type="text" name="firstName" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" value="@Model.FirstName" required />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                    <input type="text" name="lastName" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" value="@Model.LastName" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="text" class="w-full px-4 py-2 border border-gray-200 rounded-lg bg-gray-50 text-gray-500" value="@Model.Email" disabled />
            </div>

            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Role</label>
                <select name="role" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors bg-white">
                    @foreach (var role in allRoles ?? Array.Empty<string>())
                    {
                        <option value="@role" selected="@(role == currentRole ? "selected" : null)">@role</option>
                    }
                </select>
            </div>

            <div class="mb-6">
                <label class="flex items-center">
                    <input type="checkbox" name="isActive" class="w-4 h-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded" value="true"
                           @(Model.IsActive ? "checked" : "") id="isActive" />
                    <input type="hidden" name="isActive" value="false" />
                    <span class="ml-2 text-sm text-gray-700">Active Account</span>
                </label>
            </div>

            <div class="flex gap-3">
                <button type="submit" class="flex-1 px-4 py-2 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors">
                    Save Changes
                </button>
                <a asp-action="Users" class="px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
