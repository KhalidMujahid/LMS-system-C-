@model IEnumerable<LMS.Models.Course>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Manage Courses";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
        <div>
            <a asp-action="Index" class="text-primary-600 hover:text-primary-700 text-sm mb-2 inline-flex items-center">
                <i class="bi bi-arrow-left mr-1"></i>Back to Dashboard
            </a>
            <h2 class="text-2xl font-bold text-gray-900">All Courses</h2>
        </div>
        <span class="mt-2 sm:mt-0 inline-flex items-center px-3 py-1 bg-gray-100 text-gray-700 text-sm font-medium rounded-full">@Model.Count() courses</span>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Image</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Title</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Instructor</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Category</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Students</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Created</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var course in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4">
                                @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                                {
                                    <img src="@course.ThumbnailUrl" alt="@course.Title" class="w-16 h-12 object-cover rounded-lg" />
                                }
                                else
                                {
                                    <div class="w-16 h-12 bg-gradient-to-br from-primary-500 to-primary-700 rounded-lg flex items-center justify-center">
                                        <i class="bi bi-book text-white"></i>
                                    </div>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <span class="font-medium text-gray-900">@course.Title</span>
                            </td>
                            <td class="px-6 py-4 text-gray-600">@course.Instructor?.FullName</td>
                            <td class="px-6 py-4 text-gray-600">@(course.Category ?? "-")</td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @(course.Status == LMS.Models.CourseStatus.Published ? "bg-green-100 text-green-700" : course.Status == LMS.Models.CourseStatus.Draft ? "bg-amber-100 text-amber-700" : "bg-gray-100 text-gray-700")">
                                    @course.Status
                                </span>
                            </td>
                            <td class="px-6 py-4 text-gray-600">@course.EnrollmentCount</td>
                            <td class="px-6 py-4 text-gray-500 text-sm">@course.CreatedAt.ToString("MMM d, yyyy")</td>
                            <td class="px-6 py-4">
                                <form asp-action="DeleteCourse" method="post" class="inline"
                                      onsubmit="return confirm('Delete this course and all its content?')">
                                    <input type="hidden" name="id" value="@course.Id" />
                                    <button type="submit" class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
