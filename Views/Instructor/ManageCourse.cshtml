@model LMS.Models.Course
@using LMS.Models
@{
    ViewData["Title"] = "Manage: " + Model.Title;
    var liveClasses = ViewBag.LiveClasses as List<LiveClass> ?? new List<LiveClass>();
}

<div class="bg-gradient-to-r from-green-600 to-emerald-500 text-white py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
            <div class="mb-3 sm:mb-0">
                <a asp-action="Index" class="text-white/80 hover:text-white text-sm mb-1 inline-flex items-center">
                    <i class="bi bi-arrow-left mr-1"></i>My Courses
                </a>
                <h3 class="text-xl font-bold">@Model.Title</h3>
            </div>
            <div class="flex items-center gap-2">
                <a asp-action="EditCourse" asp-route-id="@Model.Id" class="px-3 py-1.5 bg-white/20 text-white text-sm font-medium rounded-lg hover:bg-white/30 transition-colors">
                    <i class="bi bi-pencil mr-1"></i>Edit
                </a>
                <span class="px-3 py-1.5 bg-white text-green-700 text-sm font-medium rounded-lg">@Model.Status</span>
            </div>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <h4 class="text-lg font-bold text-gray-900">
                    <i class="bi bi-book mr-2 text-primary-600"></i>Lessons (@Model.Lessons.Count)
                </h4>
                <a asp-action="AddLesson" asp-route-courseId="@Model.Id" class="px-3 py-1.5 bg-primary-600 text-white text-sm font-medium rounded-lg hover:bg-primary-700 transition-colors">
                    <i class="bi bi-plus mr-1"></i>Add Lesson
                </a>
            </div>
            @if (!Model.Lessons.Any())
            {
                <div class="bg-blue-50 border border-blue-200 text-blue-700 px-4 py-3 rounded-lg text-sm">
                    No lessons yet. <a asp-action="AddLesson" asp-route-courseId="@Model.Id" class="font-medium underline">Add your first lesson</a>
                </div>
            }
            else
            {
                <div class="space-y-2">
                    @foreach (var lesson in Model.Lessons.OrderBy(l => l.Order))
                    {
                        <div class="flex items-center p-3 border border-gray-100 rounded-lg hover:bg-gray-50 transition-colors">
                            <span class="text-gray-400 text-sm mr-3">@lesson.Order.</span>
                            <div class="flex-1">
                                <p class="font-medium text-gray-900 text-sm">@lesson.Title</p>
                                <p class="text-gray-500 text-xs">@lesson.Type • @lesson.DurationMinutes min</p>
                            </div>
                            <form asp-action="DeleteLesson" method="post" class="inline">
                                <input type="hidden" name="id" value="@lesson.Id" />
                                <input type="hidden" name="courseId" value="@Model.Id" />
                                <button type="submit" class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors"
                                        onclick="return confirm('Delete this lesson?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <h4 class="text-lg font-bold text-gray-900">
                    <i class="bi bi-patch-question mr-2 text-amber-500"></i>Quizzes (@Model.Quizzes.Count)
                </h4>
                <a asp-action="CreateQuiz" asp-route-courseId="@Model.Id" class="px-3 py-1.5 bg-amber-500 text-white text-sm font-medium rounded-lg hover:bg-amber-600 transition-colors">
                    <i class="bi bi-plus mr-1"></i>Add Quiz
                </a>
            </div>
            @if (!Model.Quizzes.Any())
            {
                <div class="bg-blue-50 border border-blue-200 text-blue-700 px-4 py-3 rounded-lg text-sm">
                    No quizzes yet. <a asp-action="CreateQuiz" asp-route-courseId="@Model.Id" class="font-medium underline">Create a quiz</a>
                </div>
            }
            else
            {
                <div class="space-y-2">
                    @foreach (var quiz in Model.Quizzes)
                    {
                        <div class="flex items-center justify-between p-3 border border-gray-100 rounded-lg">
                            <div>
                                <p class="font-medium text-gray-900">@quiz.Title</p>
                                <p class="text-gray-500 text-xs">@quiz.Questions.Count questions</p>
                            </div>
                            <a asp-action="ManageQuiz" asp-route-id="@quiz.Id" class="px-3 py-1.5 border border-amber-500 text-amber-600 text-sm font-medium rounded-lg hover:bg-amber-50 transition-colors">
                                Manage
                            </a>
                        </div>
                    }
                </div>
            }
        </div>
        
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <h4 class="text-lg font-bold text-gray-900">
                    <i class="bi bi-camera-video mr-2 text-red-500"></i>Live Classes (@liveClasses.Count)
                </h4>
                <a asp-controller="LiveClass" asp-action="Create" asp-route-courseId="@Model.Id" class="px-3 py-1.5 bg-red-500 text-white text-sm font-medium rounded-lg hover:bg-red-600 transition-colors">
                    <i class="bi bi-plus mr-1"></i>Schedule Class
                </a>
            </div>
            @if (!liveClasses.Any())
            {
                <div class="bg-gray-50 border border-gray-200 text-gray-600 px-4 py-3 rounded-lg text-sm">
                    No live classes scheduled. <a asp-controller="LiveClass" asp-action="Create" asp-route-courseId="@Model.Id" class="font-medium underline">Schedule a live class</a>
                </div>
            }
            else
            {
                <div class="space-y-2">
                    @foreach (var liveClass in liveClasses)
                    {
                        <div class="flex items-center justify-between p-3 border border-gray-100 rounded-lg">
                            <div>
                                <p class="font-medium text-gray-900">@liveClass.Title</p>
                                <p class="text-gray-500 text-xs">
                                    @liveClass.ScheduledAt.ToString("MMM d, yyyy 'at' h:mm tt") 
                                    (@liveClass.DurationMinutes min)
                                    @if (liveClass.Status == LiveClassStatus.Live)
                                    {
                                        <span class="text-red-500 font-medium ml-2">● LIVE</span>
                                    }
                                    else if (liveClass.Status == LiveClassStatus.Completed)
                                    {
                                        <span class="text-gray-400 ml-2">Completed</span>
                                    }
                                </p>
                            </div>
                            <div class="flex items-center gap-2">
                                @if (liveClass.Status == LiveClassStatus.Scheduled)
                                {
                                    <a asp-controller="LiveClass" asp-action="Start" asp-route-id="@liveClass.Id" class="px-3 py-1.5 bg-red-500 text-white text-sm font-medium rounded-lg hover:bg-red-600 transition-colors">
                                        Start
                                    </a>
                                }
                                else if (liveClass.Status == LiveClassStatus.Live)
                                {
                                    <a href="@liveClass.MeetingUrl" target="_blank" class="px-3 py-1.5 bg-red-500 text-white text-sm font-medium rounded-lg hover:bg-red-600 transition-colors">
                                        <i class="bi bi-camera-video-fill mr-1"></i>Join
                                    </a>
                                }
                                <a asp-controller="LiveClass" asp-action="Manage" asp-route-id="@liveClass.Id" class="px-3 py-1.5 border border-gray-300 text-gray-600 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
                                    Manage
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h4 class="text-lg font-bold text-gray-900 mb-4">
            <i class="bi bi-people mr-2 text-blue-600"></i>Enrolled Students (@Model.Enrollments.Count)
        </h4>
        @if (!Model.Enrollments.Any())
        {
            <div class="bg-gray-50 border border-gray-200 text-gray-600 px-4 py-3 rounded-lg text-sm">
                No students enrolled yet.
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Student</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Enrolled</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Progress</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var enrollment in Model.Enrollments)
                        {
                            <tr>
                                <td class="px-4 py-3 font-medium text-gray-900">@enrollment.User?.FullName</td>
                                <td class="px-4 py-3 text-gray-500 text-sm">@enrollment.EnrolledAt.ToString("MMM d, yyyy")</td>
                                <td class="px-4 py-3">
                                    <div class="flex items-center gap-2">
                                        <div class="w-24 bg-gray-100 rounded-full h-2">
                                            <div class="bg-primary-600 h-2 rounded-full" style="width: @enrollment.ProgressPercentage%"></div>
                                        </div>
                                        <span class="text-sm text-gray-600">@enrollment.ProgressPercentage%</span>
                                    </div>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @(enrollment.Status == LMS.Models.EnrollmentStatus.Completed ? "bg-green-100 text-green-700" : "bg-primary-100 text-primary-700")">
                                        @enrollment.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
