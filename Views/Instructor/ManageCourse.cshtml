@model LMS.Models.Course
@{
    ViewData["Title"] = "Manage: " + Model.Title;
}

<div class="bg-success text-white py-3">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <a asp-action="Index" class="text-white text-decoration-none small"><i class="bi bi-arrow-left me-1"></i>My Courses</a>
            <h4 class="mb-0 fw-bold mt-1">@Model.Title</h4>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="EditCourse" asp-route-id="@Model.Id" class="btn btn-outline-light btn-sm">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <span class="badge @(Model.Status == LMS.Models.CourseStatus.Published ? "bg-light text-success" : "bg-warning text-dark") align-self-center">@Model.Status</span>
        </div>
    </div>
</div>

<div class="container py-4">
    <div class="row">
        <!-- Lessons -->
        <div class="col-lg-6 mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="bi bi-book me-2 text-primary"></i>Lessons (@Model.Lessons.Count)</h5>
                <a asp-action="AddLesson" asp-route-courseId="@Model.Id" class="btn btn-primary btn-sm">
                    <i class="bi bi-plus me-1"></i>Add Lesson
                </a>
            </div>
            @if (!Model.Lessons.Any())
            {
                <div class="alert alert-info">No lessons yet. <a asp-action="AddLesson" asp-route-courseId="@Model.Id">Add your first lesson</a></div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var lesson in Model.Lessons.OrderBy(l => l.Order))
                    {
                        <div class="list-group-item d-flex align-items-center gap-2">
                            <span class="text-muted small">@lesson.Order.</span>
                            <div class="flex-grow-1">
                                <strong class="small">@lesson.Title</strong>
                                <div class="text-muted" style="font-size:0.75rem;">
                                    @lesson.Type • @lesson.DurationMinutes min
                                </div>
                            </div>
                            <form asp-action="DeleteLesson" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@lesson.Id" />
                                <input type="hidden" name="courseId" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                        onclick="return confirm('Delete this lesson?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Quizzes -->
        <div class="col-lg-6 mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="bi bi-patch-question me-2 text-warning"></i>Quizzes (@Model.Quizzes.Count)</h5>
                <a asp-action="CreateQuiz" asp-route-courseId="@Model.Id" class="btn btn-warning btn-sm">
                    <i class="bi bi-plus me-1"></i>Add Quiz
                </a>
            </div>
            @if (!Model.Quizzes.Any())
            {
                <div class="alert alert-info">No quizzes yet. <a asp-action="CreateQuiz" asp-route-courseId="@Model.Id">Create a quiz</a></div>
            }
            else
            {
                @foreach (var quiz in Model.Quizzes)
                {
                    <div class="card mb-2">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@quiz.Title</strong>
                                <small class="d-block text-muted">@quiz.Questions.Count questions</small>
                            </div>
                            <a asp-action="ManageQuiz" asp-route-id="@quiz.Id" class="btn btn-outline-warning btn-sm">
                                Manage
                            </a>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Enrolled Students -->
        <div class="col-12">
            <h5 class="fw-bold mb-3"><i class="bi bi-people me-2 text-info"></i>Enrolled Students (@Model.Enrollments.Count)</h5>
            @if (!Model.Enrollments.Any())
            {
                <div class="alert alert-info">No students enrolled yet.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>Enrolled</th>
                                <th>Progress</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var enrollment in Model.Enrollments)
                            {
                                <tr>
                                    <td>@enrollment.User?.FullName</td>
                                    <td class="text-muted small">@enrollment.EnrolledAt.ToString("MMM d, yyyy")</td>
                                    <td>
                                        <div class="progress" style="height:8px; width:100px;">
                                            <div class="progress-bar" style="width:@enrollment.ProgressPercentage%"></div>
                                        </div>
                                        <small>@enrollment.ProgressPercentage%</small>
                                    </td>
                                    <td>
                                        <span class="badge @(enrollment.Status == LMS.Models.EnrollmentStatus.Completed ? "bg-success" : "bg-primary")">
                                            @enrollment.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
