@model IEnumerable<LMS.Models.Course>
@{
    ViewData["Title"] = "Instructor Dashboard";
}

<div class="position-relative overflow-hidden" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
    <div class="container py-5 position-relative" style="z-index: 2;">
        <div class="row align-items-center text-white">
            <div class="col-lg-8">
                <h1 class="display-5 fw-bold mb-2">
                    <i class="bi bi-person-workspace me-2"></i>Instructor Dashboard
                </h1>
                <p class="lead mb-0 opacity-90">
                    Create, manage, and track your courses and students
                </p>
            </div>
            <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                <a asp-action="CreateCourse" class="btn btn-light btn-lg shadow">
                    <i class="bi bi-plus-circle me-2"></i>Create Course
                </a>
            </div>
        </div>
    </div>
    <div class="position-absolute top-0 start-0 w-100 h-100" style="z-index: 1; opacity: 0.1;">
        <div class="position-absolute" style="top: 20%; right: 10%; animation: float 8s ease-in-out infinite;">
            <i class="bi bi-book fs-1"></i>
        </div>
        <div class="position-absolute" style="bottom: 20%; left: 15%; animation: float 6s ease-in-out infinite 1s;">
            <i class="bi bi-people fs-2"></i>
        </div>
    </div>
</div>

<style>
    @@keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-20px); }
    }
</style>

<div class="container py-5">
    <div class="row g-4 mb-5">
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow stats-card h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted mb-1 small text-uppercase fw-semibold">My Courses</p>
                            <h2 class="fw-bold mb-0 display-6">@ViewBag.TotalCourses</h2>
                        </div>
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-book fs-3"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="badge bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-graph-up me-1"></i>Total Created
                        </span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow stats-card h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted mb-1 small text-uppercase fw-semibold">Total Students</p>
                            <h2 class="fw-bold mb-0 display-6">@ViewBag.TotalStudents</h2>
                        </div>
                        <div class="icon-circle bg-success bg-opacity-10 text-success">
                            <i class="bi bi-people fs-3"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="badge bg-success bg-opacity-10 text-success">
                            <i class="bi bi-person-check me-1"></i>Enrolled
                        </span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow stats-card h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted mb-1 small text-uppercase fw-semibold">Published</p>
                            <h2 class="fw-bold mb-0 display-6">@ViewBag.PublishedCourses</h2>
                        </div>
                        <div class="icon-circle bg-warning bg-opacity-10 text-warning">
                            <i class="bi bi-check-circle fs-3"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="badge bg-warning bg-opacity-10 text-warning">
                            <i class="bi bi-eye me-1"></i>Live Courses
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">My Courses</h3>
            <p class="text-muted mb-0">Manage and track your course content</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <div class="icon-circle bg-success bg-opacity-10 text-success mb-3 mx-auto" style="width: 80px; height: 80px;">
                    <i class="bi bi-book fs-1"></i>
                </div>
                <h4 class="fw-bold mb-2">No courses yet</h4>
                <p class="text-muted mb-4">Create your first course and start teaching</p>
                <a asp-action="CreateCourse" class="btn btn-success btn-lg px-5">
                    <i class="bi bi-plus-circle me-2"></i>Create Course
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var course in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow hover-card">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge @(course.Status == LMS.Models.CourseStatus.Published ? "bg-success" : "bg-warning") bg-opacity-10 @(course.Status == LMS.Models.CourseStatus.Published ? "text-success" : "text-warning") px-3 py-2">
                                    <i class="bi @(course.Status == LMS.Models.CourseStatus.Published ? "bi-check-circle" : "bi-clock-history") me-1"></i>
                                    @course.Status
                                </span>
                                <small class="text-muted">
                                    <i class="bi bi-calendar3 me-1"></i>
                                    @course.CreatedAt.ToString("MMM d, yyyy")
                                </small>
                            </div>
                            
                            <h5 class="card-title fw-bold mb-3">@course.Title</h5>
                            
                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <div class="d-flex align-items-center text-muted small">
                                        <div class="icon-circle bg-primary bg-opacity-10 text-primary me-2" style="width: 32px; height: 32px;">
                                            <i class="bi bi-book" style="font-size: 0.875rem;"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@course.LessonCount</div>
                                            <div class="small">Lessons</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="d-flex align-items-center text-muted small">
                                        <div class="icon-circle bg-success bg-opacity-10 text-success me-2" style="width: 32px; height: 32px;">
                                            <i class="bi bi-people" style="font-size: 0.875rem;"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@course.EnrollmentCount</div>
                                            <div class="small">Students</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 p-4 pt-0">
                            <div class="d-flex gap-2">
                                <a asp-action="ManageCourse" asp-route-id="@course.Id" class="btn btn-primary flex-grow-1">
                                    <i class="bi bi-gear me-1"></i>Manage
                                </a>
                                <a asp-action="EditCourse" asp-route-id="@course.Id" class="btn btn-outline-secondary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
