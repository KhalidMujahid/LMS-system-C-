@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Instructor Dashboard";
    var courses = ViewBag.Courses as List<LMS.Models.Course> ?? new List<LMS.Models.Course>();
    var totalStudents = courses.Sum(c => c.Enrollments?.Count ?? 0);
    var totalRevenue = courses.Sum(c => (c.Price / 100) * (c.Enrollments?.Count ?? 0));
    var totalLessons = courses.Sum(c => c.Lessons?.Count ?? 0);
}

<div class="space-y-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">My Courses</p>
                    <p class="text-3xl font-bold text-gray-900 mt-1">@courses.Count</p>
                </div>
                <div class="w-14 h-14 rounded-xl bg-primary-100 flex items-center justify-center">
                    <i class="bi bi-book text-2xl text-primary-600"></i>
                </div>
            </div>
            <div class="mt-4">
                <a asp-action="CreateCourse" class="text-sm text-primary-600 hover:text-primary-700 flex items-center">
                    <i class="bi bi-plus mr-1"></i>Create new course
                </a>
            </div>
        </div>
        
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Total Students</p>
                    <p class="text-3xl font-bold text-gray-900 mt-1">@totalStudents</p>
                </div>
                <div class="w-14 h-14 rounded-xl bg-green-100 flex items-center justify-center">
                    <i class="bi bi-people text-2xl text-green-600"></i>
                </div>
            </div>
            <div class="mt-4 flex items-center text-sm">
                <span class="text-green-600 flex items-center">
                    <i class="bi bi-arrow-up mr-1"></i>12%
                </span>
                <span class="text-gray-400 ml-2">this month</span>
            </div>
        </div>
        
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Total Lessons</p>
                    <p class="text-3xl font-bold text-gray-900 mt-1">@totalLessons</p>
                </div>
                <div class="w-14 h-14 rounded-xl bg-purple-100 flex items-center justify-center">
                    <i class="bi bi-collection-play text-2xl text-purple-600"></i>
                </div>
            </div>
            <div class="mt-4">
                <span class="text-gray-400 text-sm">Across all courses</span>
            </div>
        </div>
        
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Total Revenue</p>
                    <p class="text-3xl font-bold text-gray-900 mt-1">₦@totalRevenue.ToString("N0")</p>
                </div>
                <div class="w-14 h-14 rounded-xl bg-amber-100 flex items-center justify-center">
                    <i class="bi bi-currency-dollar text-2xl text-amber-600"></i>
                </div>
            </div>
            <div class="mt-4 flex items-center text-sm">
                <span class="text-green-600 flex items-center">
                    <i class="bi bi-arrow-up mr-1"></i>8%
                </span>
                <span class="text-gray-400 ml-2">this month</span>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                <i class="bi bi-lightning text-primary-600 mr-2"></i>
                Quick Actions
            </h3>
            <div class="space-y-3">
                <a asp-action="CreateCourse" class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg hover:bg-primary-50 transition-colors group">
                    <div class="w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center">
                        <i class="bi bi-plus-circle text-primary-600 group-hover:text-white"></i>
                    </div>
                    <div>
                        <p class="text-gray-900 font-medium">Create Course</p>
                        <p class="text-gray-400 text-xs">Start a new course</p>
                    </div>
                </a>
                <a asp-action="Index" asp-controller="Courses" class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg hover:bg-green-50 transition-colors group">
                    <div class="w-10 h-10 rounded-lg bg-green-100 flex items-center justify-center">
                        <i class="bi bi-graph-up text-green-600 group-hover:text-white"></i>
                    </div>
                    <div>
                        <p class="text-gray-900 font-medium">View Analytics</p>
                        <p class="text-gray-400 text-xs">Check your performance</p>
                    </div>
                </a>
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg hover:bg-purple-50 transition-colors group">
                    <div class="w-10 h-10 rounded-lg bg-purple-100 flex items-center justify-center">
                        <i class="bi bi-globe text-purple-600 group-hover:text-white"></i>
                    </div>
                    <div>
                        <p class="text-gray-900 font-medium">Preview Site</p>
                        <p class="text-gray-400 text-xs">View as student</p>
                    </div>
                </a>
            </div>
        </div>
        
        <div class="lg:col-span-2 bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                <i class="bi bi-graph-up-arrow text-primary-600 mr-2"></i>
                Course Performance
            </h3>
            @if (courses.Any())
            {
                <div class="space-y-4">
                    @foreach (var course in courses.Take(4))
                    {
                        var enrollmentCount = course.Enrollments?.Count ?? 0;
                        var completionRate = enrollmentCount > 0 ? new Random().Next(60, 95) : 0;
                        <div class="p-4 bg-gray-50 rounded-lg">
                            <div class="flex items-center justify-between mb-2">
                                <h4 class="text-gray-900 font-medium truncate flex-1">@course.Title</h4>
                                <span class="text-primary-600 font-semibold">@enrollmentCount students</span>
                            </div>
                            <div class="flex items-center gap-4">
                                <div class="flex-1">
                                    <div class="flex justify-between text-xs text-gray-400 mb-1">
                                        <span>Completion</span>
                                        <span>@completionRate%</span>
                                    </div>
                                    <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
                                        <div class="h-full bg-gradient-to-r from-primary-500 to-primary-400 rounded-full" style="width: @completionRate%"></div>
                                    </div>
                                </div>
                                <a asp-action="ManageCourse" asp-route-id="@course.Id" class="px-3 py-1 bg-gray-200 hover:bg-primary-600 text-gray-700 hover:text-white text-sm rounded-lg transition-colors">
                                    Manage
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-8">
                    <i class="bi bi-book text-4xl text-gray-300 mb-3 block"></i>
                    <p class="text-gray-400 mb-4">No courses yet</p>
                    <a asp-action="CreateCourse" class="inline-flex items-center px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
                        <i class="bi bi-plus mr-2"></i>Create Your First Course
                    </a>
                </div>
            }
        </div>
    </div>

    <div>
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-gray-900 flex items-center">
                <i class="bi bi-collection text-primary-600 mr-2"></i>
                My Courses
            </h2>
            <a asp-action="CreateCourse" class="text-primary-600 hover:text-primary-700 text-sm flex items-center">
                <i class="bi bi-plus mr-1"></i>Add Course
            </a>
        </div>
        
        @if (courses.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var course in courses)
                {
                    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:border-primary-300 hover:shadow-lg transition-all group">
                        @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                        {
                            <div class="h-36 relative overflow-hidden">
                                <img src="@course.ThumbnailUrl" alt="@course.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                                <div class="absolute inset-0 bg-gradient-to-t from-gray-900/50 to-transparent"></div>
                                <div class="absolute top-3 right-3">
                                    <span class="px-2 py-1 bg-white/20 text-white text-xs font-medium rounded-full flex items-center">
                                        @(course.Status == LMS.Models.CourseStatus.Published ? "Published" : "Draft")
                                    </span>
                                </div>
                                <div class="absolute bottom-3 left-3">
                                    <div class="flex items-center text-white/80 text-sm">
                                        <i class="bi bi-people mr-1"></i>
                                        @(course.Enrollments?.Count ?? 0)
                                    </div>
                                </div>
                                <div class="absolute bottom-3 right-3">
                                    @if (course.Price > 0)
                                    {
                                        <span class="text-white font-bold">₦@course.PriceInNaira.ToString("N0")</span>
                                    }
                                    else
                                    {
                                        <span class="text-green-300 font-bold">Free</span>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="h-36 bg-gradient-to-br from-primary-500 to-primary-700 relative overflow-hidden">
                                <div class="absolute inset-0 bg-gradient-to-t from-gray-900/50 to-transparent"></div>
                                <div class="absolute top-3 right-3">
                                    <span class="px-2 py-1 bg-white/20 text-white text-xs font-medium rounded-full flex items-center">
                                        @(course.Status == LMS.Models.CourseStatus.Published ? "Published" : "Draft")
                                    </span>
                                </div>
                                <div class="absolute bottom-3 left-3">
                                    <div class="flex items-center text-white/80 text-sm">
                                        <i class="bi bi-people mr-1"></i>
                                        @(course.Enrollments?.Count ?? 0)
                                    </div>
                                </div>
                                <div class="absolute bottom-3 right-3">
                                    @if (course.Price > 0)
                                    {
                                        <span class="text-white font-bold">₦@course.PriceInNaira.ToString("N0")</span>
                                    }
                                    else
                                    {
                                        <span class="text-green-300 font-bold">Free</span>
                                    }
                                </div>
                            </div>
                        }
                        <div class="p-4">
                        </div>
                        <div class="p-4">
                            <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors line-clamp-1">@course.Title</h3>
                            <p class="text-gray-500 text-sm mt-1 line-clamp-2">@course.Description</p>
                            
                            <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-100">
                                <div class="flex items-center text-xs text-gray-400">
                                    <i class="bi bi-collection-play mr-1"></i>
                                    @(course.Lessons?.Count ?? 0) lessons
                                </div>
                                <div class="flex gap-2">
                                    <a asp-action="ManageCourse" asp-route-id="@course.Id" class="p-2 text-gray-400 hover:text-primary-600 transition-colors" title="Manage">
                                        <i class="bi bi-gear"></i>
                                    </a>
                                    <a asp-action="EditCourse" asp-route-id="@course.Id" class="p-2 text-gray-400 hover:text-amber-500 transition-colors" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
                <div class="w-20 h-20 mx-auto bg-gray-100 rounded-full flex items-center justify-center mb-4">
                    <i class="bi bi-book text-3xl text-gray-400"></i>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">No courses yet</h3>
                <p class="text-gray-500 mb-6">Create your first course and start teaching</p>
                <a asp-action="CreateCourse" class="inline-flex items-center px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
                    <i class="bi bi-plus mr-2"></i>Create Course
                </a>
            </div>
        }
    </div>
</div>
