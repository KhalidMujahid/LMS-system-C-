@model LMS.Models.Quiz
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Create Quiz";
    var course = ViewBag.Course as LMS.Models.Course;
}

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center mb-6">
        <a asp-action="ManageCourse" asp-route-id="@Model.CourseId" class="p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors mr-3">
            <i class="bi bi-arrow-left text-lg"></i>
        </a>
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Create Quiz</h2>
            <p class="text-gray-500 text-sm">@course?.Title</p>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <form asp-action="CreateQuiz" method="post">
            <input type="hidden" asp-for="CourseId" />
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div asp-validation-summary="All" class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg text-sm mb-4"></div>
            }

            <div class="mb-4">
                <label asp-for="Title" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Title" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" />
                <span asp-validation-for="Title" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <textarea asp-for="Description" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" rows="3"></textarea>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
                <div>
                    <label asp-for="PassingScore" class="block text-sm font-medium text-gray-700 mb-1">Passing Score (%)</label>
                    <input asp-for="PassingScore" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" type="number" min="1" max="100" />
                </div>
                <div>
                    <label asp-for="TimeLimitMinutes" class="block text-sm font-medium text-gray-700 mb-1">Time Limit (min)</label>
                    <input asp-for="TimeLimitMinutes" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" type="number" min="1" />
                </div>
            </div>

            <div class="flex gap-3">
                <button type="submit" class="flex-1 px-4 py-2.5 bg-amber-500 text-white font-medium rounded-lg hover:bg-amber-600 transition-colors">
                    <i class="bi bi-plus-circle mr-2"></i>Create Quiz
                </button>
                <a asp-action="ManageCourse" asp-route-id="@Model.CourseId" class="px-4 py-2.5 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
