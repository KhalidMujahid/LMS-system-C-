@model LMS.Models.Lesson
@{
    ViewData["Title"] = "Add Lesson";
    var course = ViewBag.Course as LMS.Models.Course;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="d-flex align-items-center mb-4">
                <a asp-action="ManageCourse" asp-route-id="@Model.CourseId" class="btn btn-outline-secondary me-3">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h3 class="fw-bold mb-0">Add Lesson</h3>
                    <small class="text-muted">@course?.Title</small>
                </div>
            </div>
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="AddLesson" method="post">
                        <input type="hidden" asp-for="CourseId" />
                        <div asp-validation-summary="All" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Type" class="form-label fw-semibold"></label>
                                <select asp-for="Type" class="form-select">
                                    <option value="1">Text</option>
                                    <option value="0">Video</option>
                                    <option value="2">Document</option>
                                </select>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="Order" class="form-label fw-semibold"></label>
                                <input asp-for="Order" class="form-control" type="number" min="1" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="DurationMinutes" class="form-label fw-semibold">Duration (min)</label>
                                <input asp-for="DurationMinutes" class="form-control" type="number" min="1" />
                            </div>
                        </div>

                        <div class="mb-3" id="videoUrlField">
                            <label asp-for="VideoUrl" class="form-label fw-semibold">Video URL (optional)</label>
                            <input asp-for="VideoUrl" class="form-control" placeholder="https://..." />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Content" class="form-label fw-semibold">Lesson Content</label>
                            <textarea asp-for="Content" class="form-control" rows="8"
                                      placeholder="Write your lesson content here..."></textarea>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-plus-circle me-2"></i>Add Lesson
                            </button>
                            <a asp-action="ManageCourse" asp-route-id="@Model.CourseId" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
