@model LMS.Models.Lesson
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Add Lesson";
    var course = ViewBag.Course as LMS.Models.Course;
}

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center mb-6">
        <a asp-action="ManageCourse" asp-route-id="@Model.CourseId" class="p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors mr-3">
            <i class="bi bi-arrow-left text-lg"></i>
        </a>
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Add Lesson</h2>
            <p class="text-gray-500 text-sm">@course?.Title</p>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <form asp-action="AddLesson" method="post">
            <input type="hidden" asp-for="CourseId" />
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div asp-validation-summary="All" class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg text-sm mb-4"></div>
            }

            <div class="mb-4">
                <label asp-for="Title" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Title" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" />
                <span asp-validation-for="Title" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-4">
                <div class="col-span-2 sm:col-span-1">
                    <label asp-for="Type" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <select asp-for="Type" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors bg-white">
                        <option value="1">Text</option>
                        <option value="0">Video</option>
                        <option value="2">Document</option>
                    </select>
                </div>
                <div>
                    <label asp-for="Order" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input asp-for="Order" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" type="number" min="1" />
                </div>
                <div>
                    <label asp-for="DurationMinutes" class="block text-sm font-medium text-gray-700 mb-1">Duration (min)</label>
                    <input asp-for="DurationMinutes" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" type="number" min="1" />
                </div>
            </div>

            <div class="mb-4" id="videoUrlField">
                <label asp-for="VideoUrl" class="block text-sm font-medium text-gray-700 mb-1">Video URL (optional)</label>
                <input asp-for="VideoUrl" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" placeholder="https://..." />
            </div>

            <div class="mb-6">
                <label asp-for="Content" class="block text-sm font-medium text-gray-700 mb-1">Lesson Content</label>
                <textarea asp-for="Content" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" rows="8"
                          placeholder="Write your lesson content here..."></textarea>
            </div>

            <div class="flex gap-3">
                <button type="submit" class="flex-1 px-4 py-2.5 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors">
                    <i class="bi bi-plus-circle mr-2"></i>Add Lesson
                </button>
                <a asp-action="ManageCourse" asp-route-id="@Model.CourseId" class="px-4 py-2.5 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
