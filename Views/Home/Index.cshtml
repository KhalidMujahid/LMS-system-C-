@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="bg-primary text-white py-5 position-relative overflow-hidden">
    <div class="container py-5 position-relative" style="z-index: 2;">
        <div class="row align-items-center">
            <div class="col-lg-7 fade-in">
                <div class="badge bg-white text-primary mb-3 px-3 py-2">
                    <i class="bi bi-star-fill me-1"></i>
                    Trusted by 10,000+ learners
                </div>
                <h1 class="display-3 fw-bold mb-4" style="line-height: 1.1;">
                    Learn Without Limits
                </h1>
                <p class="lead mb-4 fs-4" style="opacity: 0.95;">
                    Access thousands of courses from expert instructors. Build real-world skills and advance your career with our comprehensive learning platform.
                </p>
                <div class="d-flex flex-wrap gap-3 mb-4">
                    <a asp-controller="Courses" asp-action="Index" class="btn btn-light btn-lg px-5 shadow">
                        <i class="bi bi-search me-2"></i>Explore Courses
                    </a>
                    @if (!User.Identity!.IsAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg px-5">
                            <i class="bi bi-rocket-takeoff me-2"></i>Get Started Free
                        </a>
                    }
                </div>
                <div class="d-flex align-items-center gap-4 text-white-50 small">
                    <div>
                        <i class="bi bi-check-circle-fill me-1"></i>
                        No credit card required
                    </div>
                    <div>
                        <i class="bi bi-check-circle-fill me-1"></i>
                        Cancel anytime
                    </div>
                </div>
            </div>
            <div class="col-lg-5 text-center d-none d-lg-block position-relative">
                <div class="position-relative" style="animation: float 6s ease-in-out infinite;">
                    <i class="bi bi-mortarboard" style="font-size: 12rem; opacity: 0.15;"></i>
                    <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
                        <div class="text-center">
                            <div class="bg-white text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-2" 
                                 style="width: 80px; height: 80px; animation: pulse 2s ease-in-out infinite;">
                                <i class="bi bi-play-fill fs-1"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Animated Background Elements -->
    <div class="position-absolute top-0 start-0 w-100 h-100" style="z-index: 1; opacity: 0.1;">
        <div class="position-absolute" style="top: 10%; left: 10%; animation: float 8s ease-in-out infinite;">
            <i class="bi bi-book fs-1"></i>
        </div>
        <div class="position-absolute" style="top: 70%; left: 15%; animation: float 7s ease-in-out infinite 1s;">
            <i class="bi bi-lightbulb fs-2"></i>
        </div>
        <div class="position-absolute" style="top: 20%; right: 20%; animation: float 9s ease-in-out infinite 2s;">
            <i class="bi bi-trophy fs-1"></i>
        </div>
        <div class="position-absolute" style="bottom: 20%; right: 15%; animation: float 6s ease-in-out infinite 1.5s;">
            <i class="bi bi-star-fill fs-3"></i>
        </div>
    </div>
</div>

<style>
    @@keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-20px); }
    }
</style>

<!-- Features Section -->
<div class="container py-5 my-5">
    <div class="text-center mb-5 fade-in">
        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 mb-3">
            <i class="bi bi-stars me-1"></i>Features
        </span>
        <h2 class="display-5 fw-bold mb-3">Why Choose EduLMS?</h2>
        <p class="text-muted fs-5 mx-auto" style="max-width: 600px;">
            Everything you need to succeed in your learning journey
        </p>
    </div>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card text-center p-4">
                <div class="icon-circle bg-primary bg-opacity-10 text-primary mb-3 mx-auto">
                    <i class="bi bi-play-circle fs-2"></i>
                </div>
                <h5 class="fw-bold mb-3">Rich Content</h5>
                <p class="text-muted mb-0">
                    Video lessons, readings, and interactive quizzes to maximize learning outcomes and engagement.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card text-center p-4">
                <div class="icon-circle bg-success bg-opacity-10 text-success mb-3 mx-auto">
                    <i class="bi bi-trophy fs-2"></i>
                </div>
                <h5 class="fw-bold mb-3">Track Progress</h5>
                <p class="text-muted mb-0">
                    Monitor your learning journey with detailed progress tracking and earn completion certificates.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card text-center p-4">
                <div class="icon-circle bg-warning bg-opacity-10 text-warning mb-3 mx-auto">
                    <i class="bi bi-people fs-2"></i>
                </div>
                <h5 class="fw-bold mb-3">Expert Instructors</h5>
                <p class="text-muted mb-0">
                    Learn from industry professionals with real-world experience and proven expertise.
                </p>
            </div>
        </div>
    </div>
    
    <!-- Additional Features Row -->
    <div class="row g-4 mt-2">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card text-center p-4">
                <div class="icon-circle bg-info bg-opacity-10 text-info mb-3 mx-auto">
                    <i class="bi bi-clock-history fs-2"></i>
                </div>
                <h5 class="fw-bold mb-3">Learn at Your Pace</h5>
                <p class="text-muted mb-0">
                    Access courses anytime, anywhere. Learn on your schedule with lifetime access.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card text-center p-4">
                <div class="icon-circle bg-danger bg-opacity-10 text-danger mb-3 mx-auto">
                    <i class="bi bi-patch-check fs-2"></i>
                </div>
                <h5 class="fw-bold mb-3">Certificates</h5>
                <p class="text-muted mb-0">
                    Earn recognized certificates upon course completion to showcase your achievements.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card text-center p-4">
                <div class="icon-circle bg-primary bg-opacity-10 text-primary mb-3 mx-auto">
                    <i class="bi bi-chat-dots fs-2"></i>
                </div>
                <h5 class="fw-bold mb-3">Community Support</h5>
                <p class="text-muted mb-0">
                    Connect with fellow learners and instructors in our vibrant learning community.
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Demo Accounts Section -->
@if (!User.Identity!.IsAuthenticated)
{
    <div class="bg-light py-5 my-5">
        <div class="container py-4">
            <div class="text-center mb-5">
                <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 mb-3">
                    <i class="bi bi-key me-1"></i>Demo Access
                </span>
                <h2 class="display-5 fw-bold mb-3">Try the Demo</h2>
                <p class="text-muted fs-5 mx-auto" style="max-width: 600px;">
                    Experience the platform with different user roles. No registration required!
                </p>
            </div>
            <div class="row justify-content-center g-4 mb-4">
                <div class="col-lg-4 col-md-6">
                    <div class="card border-0 shadow hover-card h-100">
                        <div class="card-body text-center p-4">
                            <div class="icon-circle bg-danger bg-opacity-10 text-danger mb-3 mx-auto">
                                <i class="bi bi-shield-check fs-3"></i>
                            </div>
                            <h5 class="fw-bold mb-2">Admin</h5>
                            <p class="text-muted small mb-3">
                                Full platform control - manage users, courses, and system settings
                            </p>
                            <div class="bg-light rounded p-3 mb-3">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <small class="text-muted">Email:</small>
                                    <code class="small">admin@lms.com</code>
                                </div>
                                <div class="d-flex align-items-center justify-content-between">
                                    <small class="text-muted">Password:</small>
                                    <code class="small">Admin@123</code>
                                </div>
                            </div>
                            <span class="badge bg-danger bg-opacity-10 text-danger">
                                <i class="bi bi-star-fill me-1"></i>Full Access
                            </span>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6">
                    <div class="card border-0 shadow hover-card h-100">
                        <div class="card-body text-center p-4">
                            <div class="icon-circle bg-success bg-opacity-10 text-success mb-3 mx-auto">
                                <i class="bi bi-person-workspace fs-3"></i>
                            </div>
                            <h5 class="fw-bold mb-2">Instructor</h5>
                            <p class="text-muted small mb-3">
                                Create courses, manage content, and track student progress
                            </p>
                            <div class="bg-light rounded p-3 mb-3">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <small class="text-muted">Email:</small>
                                    <code class="small">instructor@lms.com</code>
                                </div>
                                <div class="d-flex align-items-center justify-content-between">
                                    <small class="text-muted">Password:</small>
                                    <code class="small">Instructor@123</code>
                                </div>
                            </div>
                            <span class="badge bg-success bg-opacity-10 text-success">
                                <i class="bi bi-pencil-fill me-1"></i>Content Creator
                            </span>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6">
                    <div class="card border-0 shadow hover-card h-100">
                        <div class="card-body text-center p-4">
                            <div class="icon-circle bg-primary bg-opacity-10 text-primary mb-3 mx-auto">
                                <i class="bi bi-book fs-3"></i>
                            </div>
                            <h5 class="fw-bold mb-2">Student</h5>
                            <p class="text-muted small mb-3">
                                Enroll in courses, complete lessons, and take quizzes
                            </p>
                            <div class="bg-light rounded p-3 mb-3">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <small class="text-muted">Email:</small>
                                    <code class="small">student@lms.com</code>
                                </div>
                                <div class="d-flex align-items-center justify-content-between">
                                    <small class="text-muted">Password:</small>
                                    <code class="small">Student@123</code>
                                </div>
                            </div>
                            <span class="badge bg-primary bg-opacity-10 text-primary">
                                <i class="bi bi-mortarboard-fill me-1"></i>Learner
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="text-center">
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-5 shadow">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Login Now
                </a>
                <p class="text-muted small mt-3 mb-0">
                    <i class="bi bi-info-circle me-1"></i>
                    Click any credential above to copy, then login
                </p>
            </div>
        </div>
    </div>
}
