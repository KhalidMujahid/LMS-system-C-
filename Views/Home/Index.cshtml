@{
    ViewData["Title"] = "Home";
}

<div class="bg-gradient-to-r from-primary-600 to-primary-800 text-white py-16 lg:py-24 relative overflow-hidden">
    <div class="absolute inset-0 z-0" style="opacity: 0.1;">
        <div class="absolute top-10 left-10 animate-pulse">
            <i class="bi bi-book text-5xl"></i>
        </div>
        <div class="absolute top-1/3 right-20 animate-pulse" style="animation-delay: 1s;">
            <i class="bi bi-lightbulb text-4xl"></i>
        </div>
        <div class="absolute top-20 right-40 animate-pulse" style="animation-delay: 2s;">
            <i class="bi bi-trophy text-5xl"></i>
        </div>
        <div class="absolute bottom-20 right-15 animate-pulse" style="animation-delay: 1.5s;">
            <i class="bi bi-star-fill text-3xl"></i>
        </div>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
                <div class="inline-flex items-center px-4 py-2 bg-white/20 rounded-full text-sm font-medium mb-6">
                    <i class="bi bi-star-fill mr-2 text-amber-400"></i>
                    Trusted by 10,000+ learners
                </div>
                <h1 class="text-4xl lg:text-5xl font-bold mb-6 leading-tight">
                    Learn Without Limits
                </h1>
                <p class="text-lg lg:text-xl text-primary-100 mb-6 max-w-xl">
                    Access thousands of courses from expert instructors. Build real-world skills and advance your career with our comprehensive learning platform.
                </p>
                <div class="flex flex-wrap gap-4 mb-6">
                    <a asp-controller="Courses" asp-action="Index" class="inline-flex items-center px-6 py-3 bg-white text-primary-700 font-semibold rounded-lg hover:bg-gray-50 transition-colors shadow-lg">
                        <i class="bi bi-search mr-2"></i>Explore Courses
                    </a>
                    @if (!User.Identity!.IsAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="Register" class="inline-flex items-center px-6 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors">
                            <i class="bi bi-rocket-takeoff mr-2"></i>Get Started Free
                        </a>
                    }
                </div>
                <div class="flex items-center gap-6 text-primary-200 text-sm">
                    <div class="flex items-center">
                        <i class="bi bi-check-circle-fill mr-2"></i>
                        No credit card required
                    </div>
                    <div class="flex items-center">
                        <i class="bi bi-check-circle-fill mr-2"></i>
                        Cancel anytime
                    </div>
                </div>
            </div>
            <div class="hidden lg:block text-center relative">
                <div class="relative inline-block">
                    <i class="bi bi-mortarboard text-primary-900/20" style="font-size: 20rem;"></i>
                    <div class="absolute inset-0 flex items-center justify-center">
                        <div class="bg-white text-primary-600 rounded-full h-24 w-24 flex items-center justify-center shadow-xl">
                            <i class="bi bi-play-fill text-4xl"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
        <span class="inline-flex items-center px-4 py-2 bg-primary-100 text-primary-700 rounded-full text-sm font-medium mb-4">
            <i class="bi bi-stars mr-2"></i>Features
        </span>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">Why Choose EduLMS?</h2>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto">
            Everything you need to succeed in your learning journey
        </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 text-center hover:shadow-lg transition-shadow">
            <div class="h-16 w-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="bi bi-play-circle text-2xl text-primary-600"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Rich Content</h3>
            <p class="text-gray-600">
                Video lessons, readings, and interactive quizzes to maximize learning outcomes and engagement.
            </p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 text-center hover:shadow-lg transition-shadow">
            <div class="h-16 w-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="bi bi-trophy text-2xl text-green-600"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Track Progress</h3>
            <p class="text-gray-600">
                Monitor your learning journey with detailed progress tracking and earn completion certificates.
            </p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 text-center hover:shadow-lg transition-shadow">
            <div class="h-16 w-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="bi bi-people text-2xl text-amber-600"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Expert Instructors</h3>
            <p class="text-gray-600">
                Learn from industry professionals with real-world experience and proven expertise.
            </p>
        </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 text-center hover:shadow-lg transition-shadow">
            <div class="h-16 w-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="bi bi-clock-history text-2xl text-blue-600"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Learn at Your Pace</h3>
            <p class="text-gray-600">
                Access courses anytime, anywhere. Learn on your schedule with lifetime access.
            </p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 text-center hover:shadow-lg transition-shadow">
            <div class="h-16 w-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="bi bi-patch-check text-2xl text-red-600"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Certificates</h3>
            <p class="text-gray-600">
                Earn recognized certificates upon course completion to showcase your achievements.
            </p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 text-center hover:shadow-lg transition-shadow">
            <div class="h-16 w-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="bi bi-chat-dots text-2xl text-purple-600"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Community Support</h3>
            <p class="text-gray-600">
                Connect with fellow learners and instructors in our vibrant learning community.
            </p>
        </div>
    </div>
</div>

@if (!User.Identity!.IsAuthenticated)
{
    <div class="bg-gray-50 py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <span class="inline-flex items-center px-4 py-2 bg-primary-100 text-primary-700 rounded-full text-sm font-medium mb-4">
                    <i class="bi bi-key mr-2"></i>Demo Access
                </span>
                <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">Try the Demo</h2>
                <p class="text-gray-600 text-lg max-w-2xl mx-auto">
                    Experience the platform with different user roles. No registration required!
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-shadow">
                    <div class="p-6 text-center">
                        <div class="h-16 w-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="bi bi-shield-check text-2xl text-red-600"></i>
                        </div>
                        <h3 class="text-xl font-bold text-gray-900 mb-2">Admin</h3>
                        <p class="text-gray-600 text-sm mb-4">
                            Full platform control - manage users, courses, and system settings
                        </p>
                        <div class="bg-gray-50 rounded-lg p-3 mb-4 text-left">
                            <div class="flex justify-between mb-1">
                                <span class="text-gray-500 text-xs">Email:</span>
                                <code class="text-xs text-gray-700">admin@lms.com</code>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-500 text-xs">Password:</span>
                                <code class="text-xs text-gray-700">Admin@123</code>
                            </div>
                        </div>
                        <span class="inline-flex items-center px-3 py-1 bg-red-100 text-red-700 text-xs font-medium rounded-full">
                            <i class="bi bi-star-fill mr-1"></i>Full Access
                        </span>
                    </div>
                </div>
                
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-shadow">
                    <div class="p-6 text-center">
                        <div class="h-16 w-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="bi bi-person-workspace text-2xl text-green-600"></i>
                        </div>
                        <h3 class="text-xl font-bold text-gray-900 mb-2">Instructor</h3>
                        <p class="text-gray-600 text-sm mb-4">
                            Create courses, manage content, and track student progress
                        </p>
                        <div class="bg-gray-50 rounded-lg p-3 mb-4 text-left">
                            <div class="flex justify-between mb-1">
                                <span class="text-gray-500 text-xs">Email:</span>
                                <code class="text-xs text-gray-700">instructor@lms.com</code>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-500 text-xs">Password:</span>
                                <code class="text-xs text-gray-700">Instructor@123</code>
                            </div>
                        </div>
                        <span class="inline-flex items-center px-3 py-1 bg-green-100 text-green-700 text-xs font-medium rounded-full">
                            <i class="bi bi-pencil-fill mr-1"></i>Content Creator
                        </span>
                    </div>
                </div>
                
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-shadow">
                    <div class="p-6 text-center">
                        <div class="h-16 w-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="bi bi-book text-2xl text-primary-600"></i>
                        </div>
                        <h3 class="text-xl font-bold text-gray-900 mb-2">Student</h3>
                        <p class="text-gray-600 text-sm mb-4">
                            Enroll in courses, complete lessons, and take quizzes
                        </p>
                        <div class="bg-gray-50 rounded-lg p-3 mb-4 text-left">
                            <div class="flex justify-between mb-1">
                                <span class="text-gray-500 text-xs">Email:</span>
                                <code class="text-xs text-gray-700">student@lms.com</code>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-500 text-xs">Password:</span>
                                <code class="text-xs text-gray-700">Student@123</code>
                            </div>
                        </div>
                        <span class="inline-flex items-center px-3 py-1 bg-primary-100 text-primary-700 text-xs font-medium rounded-full">
                            <i class="bi bi-mortarboard-fill mr-1"></i>Learner
                        </span>
                    </div>
                </div>
            </div>
            
            <div class="text-center">
                <a asp-controller="Account" asp-action="Login" class="inline-flex items-center px-6 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors shadow-lg">
                    <i class="bi bi-box-arrow-in-right mr-2"></i>Login Now
                </a>
                <p class="text-gray-500 text-sm mt-4">
                    <i class="bi bi-info-circle mr-1"></i>
                    Click any credential above to copy, then login
                </p>
            </div>
        </div>
    </div>
}
